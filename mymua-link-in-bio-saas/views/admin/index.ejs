<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Mymua</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; -webkit-font-smoothing: antialiased; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in { animation: fadeIn 0.3s ease-out; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
    .msg-in { animation: slideDown 0.25s ease-out; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #3f3f46; }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-dvh">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight">Admin</h1>
        <p class="text-zinc-500 text-sm mt-1"><%= totalUsers %> users · <%= totalBookings %> bookings</p>
      </div>
      <a href="/dashboard" class="text-sm text-zinc-400 hover:text-zinc-200 transition-colors px-4 py-2 rounded-lg border border-zinc-800 hover:border-zinc-600">My Dashboard</a>
    </div>

    <% if (msg) { %>
    <div class="msg-in mb-6 p-4 rounded-xl border text-sm flex items-center gap-3 <%= msgType === 'error' ? 'bg-red-900/20 border-red-800/40 text-red-400' : 'bg-emerald-900/20 border-emerald-800/40 text-emerald-400' %>">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><%= msgType === 'error' ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>' : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>' %></svg>
      <span><%= msg %></span>
    </div>
    <% } %>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-5 fade-in" style="animation-delay:0s">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg></div>
          <span class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Users</span>
        </div>
        <p class="text-3xl font-bold tracking-tight"><%= totalUsers %></p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-5 fade-in" style="animation-delay:0.05s">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
          <span class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Bookings</span>
        </div>
        <p class="text-3xl font-bold tracking-tight"><%= totalBookings %></p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-5 fade-in" style="animation-delay:0.1s">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg></div>
          <span class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Active MUAs</span>
        </div>
        <p class="text-3xl font-bold tracking-tight"><%= usersWithBooking %></p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800/60 rounded-2xl p-5 fade-in" style="animation-delay:0.15s">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-8 h-8 rounded-lg bg-sky-500/10 flex items-center justify-center"><svg class="w-4 h-4 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg></div>
          <span class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Templates</span>
        </div>
        <div class="space-y-1 mt-1">
          <% for (let i = 1; i <= 9; i++) {
            const stat = templateStats.find(s => s.template_id === i);
          %>
          <div class="flex items-center justify-between text-xs">
            <span class="text-zinc-400">T<%= i %> <%= templateNames[i] %></span>
            <span class="text-zinc-200 font-medium"><%= stat ? stat.c : 0 %></span>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="bg-zinc-900/40 border border-zinc-800/60 rounded-2xl overflow-hidden fade-in" style="animation-delay:0.2s">
      <div class="p-4 sm:p-5 border-b border-zinc-800/60">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <h2 class="font-semibold text-sm sm:text-base">All Users</h2>
          <form method="GET" action="/admin" class="flex items-center gap-2 w-full sm:w-auto">
            <div class="relative flex-1 sm:flex-initial">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <input type="text" name="search" value="<%= search %>" placeholder="Search users..." class="w-full sm:w-64 pl-9 pr-3 py-2 bg-zinc-800/60 border border-zinc-700/60 rounded-xl text-sm text-zinc-200 placeholder-zinc-500 focus:outline-none focus:border-zinc-500 transition-colors">
            </div>
            <button type="submit" class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-sm text-zinc-300 transition-colors">Search</button>
            <% if (search) { %>
            <a href="/admin" class="px-3 py-2 text-zinc-500 hover:text-zinc-300 text-sm transition-colors">Clear</a>
            <% } %>
          </form>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-zinc-500 text-xs uppercase tracking-wider border-b border-zinc-800/60">
              <th class="text-left p-3 sm:p-4 font-medium">User</th>
              <th class="text-left p-3 sm:p-4 font-medium hidden sm:table-cell">Email</th>
              <th class="text-left p-3 sm:p-4 font-medium">Template</th>
              <th class="text-left p-3 sm:p-4 font-medium hidden md:table-cell">Role</th>
              <th class="text-left p-3 sm:p-4 font-medium hidden lg:table-cell">Created</th>
              <th class="text-right p-3 sm:p-4 font-medium"></th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
            <tr><td colspan="6" class="p-8 text-center text-zinc-500 text-sm">No users found</td></tr>
            <% } %>
            <% users.forEach(function(u) { %>
            <tr class="border-b border-zinc-800/30 hover:bg-zinc-800/20 transition-colors">
              <td class="p-3 sm:p-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-zinc-800 flex items-center justify-center text-xs font-medium text-zinc-400 shrink-0"><%= u.username[0].toUpperCase() %></div>
                  <div>
                    <div class="font-medium text-zinc-200"><%= u.username %></div>
                    <div class="text-zinc-500 text-xs sm:hidden"><%= u.email %></div>
                  </div>
                </div>
              </td>
              <td class="p-3 sm:p-4 text-zinc-400 hidden sm:table-cell"><%= u.email %></td>
              <td class="p-3 sm:p-4">
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium <%= 'bg-violet-500/10 text-violet-400' %>">T<%= u.template_id %> <%= templateNames[u.template_id] %></span>
              </td>
              <td class="p-3 sm:p-4 hidden md:table-cell">
                <% if (u.is_admin) { %>
                <span class="px-2.5 py-1 rounded-lg text-xs font-medium bg-amber-500/10 text-amber-400">Admin</span>
                <% } else { %>
                <span class="text-zinc-500 text-xs">MUA</span>
                <% } %>
              </td>
              <td class="p-3 sm:p-4 text-zinc-500 text-xs hidden lg:table-cell"><%= u.created_at %></td>
              <td class="p-3 sm:p-4 text-right">
                <a href="/admin/user/<%= u.id %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition-colors">
                  View
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
      <div class="p-4 border-t border-zinc-800/60 flex items-center justify-between">
        <p class="text-xs text-zinc-500">Page <%= page %> of <%= totalPages %></p>
        <div class="flex items-center gap-2">
          <% if (page > 1) { %>
          <a href="?page=<%= page - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="px-3 py-1.5 rounded-lg text-xs text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition-colors">Previous</a>
          <% } %>
          <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
          <a href="?page=<%= p %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-medium transition-colors <%= p === page ? 'bg-zinc-700 text-zinc-200' : 'text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800/60' %>"><%= p %></a>
          <% } %>
          <% if (page < totalPages) { %>
          <a href="?page=<%= page + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="px-3 py-1.5 rounded-lg text-xs text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition-colors">Next</a>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</body>
</html>
