<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password — Mymua</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-dvh flex items-center justify-center p-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold tracking-tight">Mymua</h1>
      <p class="text-zinc-500 text-sm mt-1">Reset your password</p>
    </div>
    <% if (sent) { %>
    <div class="mb-4 p-4 bg-zinc-900 border border-zinc-800 rounded-xl text-center">
      <p class="text-zinc-300">Check your email for a reset link.</p>
      <p class="text-zinc-600 text-xs mt-2">If you don't see it, check spam. Link expires in 1 hour.</p>
    </div>
    <a href="/login" class="block text-center text-sm text-zinc-400 hover:text-zinc-300 underline">Back to login</a>
    <% } else { %>
    <% if (error) { %><div class="mb-4 p-3 bg-red-900/30 border border-red-800 text-red-400 text-sm rounded-lg"><%= error %></div><% } %>
    <form method="POST" action="/forgot" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Email</label>
        <input type="email" name="email" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-sm focus:outline-none focus:border-zinc-600">
      </div>
      <button type="submit" class="w-full py-3 bg-zinc-100 text-zinc-900 rounded-lg text-sm font-medium hover:bg-zinc-200">Send Reset Link</button>
    </form>
    <p class="text-center text-zinc-600 text-sm mt-6"><a href="/login" class="text-zinc-400 hover:text-zinc-300">Back to login</a></p>
    <% } %>
  </div>
</body>
</html>
