<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — Mymua</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-dvh flex items-center justify-center p-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold tracking-tight">Mymua</h1>
      <p class="text-zinc-500 text-sm mt-1">Create your brochure page</p>
    </div>
    <% if (error) { %><div class="mb-4 p-3 bg-red-900/30 border border-red-800 text-red-400 text-sm rounded-lg"><%= error %></div><% } %>
    <form method="POST" action="/register" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Username</label>
        <input type="text" name="username" required pattern="[a-zA-Z0-9_]{3,30}" class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-sm focus:outline-none focus:border-zinc-600" placeholder="e.g. priyasharma">
        <p class="text-zinc-600 text-xs mt-1">Your page will be at /your-username</p>
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Email</label>
        <input type="email" name="email" required class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-sm focus:outline-none focus:border-zinc-600">
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Password</label>
        <input type="password" name="password" required minlength="8" class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-sm focus:outline-none focus:border-zinc-600">
        <p class="text-zinc-600 text-xs mt-1">Minimum 8 characters</p>
      </div>
      <button type="submit" class="w-full py-3 bg-zinc-100 text-zinc-900 rounded-lg text-sm font-medium hover:bg-zinc-200 transition-colors">Create Account</button>
    </form>
    <p class="text-center text-zinc-600 text-sm mt-6">Already have an account? <a href="/login" class="text-zinc-400 hover:text-zinc-300">Sign in</a></p>
  </div>
</body>
</html>
