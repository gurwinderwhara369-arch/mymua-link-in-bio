<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Mymua Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .sidebar-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1rem; border-radius: 0.5rem; font-size: 0.875rem; color: #a1a1aa; transition: all 0.15s; }
    .sidebar-link:hover { background: #27272a; color: #f4f4f5; }
    .sidebar-link.active { background: #27272a; color: #f4f4f5; }
    input, select, textarea { font-size: 16px !important; }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-dvh flex">
  <!-- Sidebar -->
  <nav class="w-56 flex-shrink-0 border-r border-zinc-800 p-4 hidden md:flex flex-col">
    <a href="/dashboard" class="text-lg font-bold tracking-tight mb-6 block">Mymua</a>
    <div class="flex flex-col gap-1 flex-1">
      <a href="/dashboard" class="sidebar-link <% if (path === '/dashboard') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Overview
      </a>
      <a href="/dashboard/profile" class="sidebar-link <% if (path === '/dashboard/profile') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Profile
      </a>
      <a href="/dashboard/services" class="sidebar-link <% if (path === '/dashboard/services') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Services
      </a>
      <a href="/dashboard/gallery" class="sidebar-link <% if (path === '/dashboard/gallery') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Gallery
      </a>
      <a href="/dashboard/testimonials" class="sidebar-link <% if (path === '/dashboard/testimonials') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Testimonials
      </a>
      <a href="/dashboard/social" class="sidebar-link <% if (path === '/dashboard/social') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        Social Links
      </a>
      <a href="/dashboard/templates" class="sidebar-link <% if (path === '/dashboard/templates') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
        Templates
      </a>
      <a href="/dashboard/bookings" class="sidebar-link <% if (path === '/dashboard/bookings') { %>active<% } %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Bookings
      </a>
    </div>
    <form method="POST" action="/logout" class="mt-auto">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="sidebar-link w-full text-zinc-600 hover:text-red-400">Sign Out</button>
    </form>
  </nav>

  <!-- Mobile header -->
  <div class="flex-1 flex flex-col min-h-dvh">
    <header class="md:hidden flex items-center justify-between p-4 border-b border-zinc-800">
      <a href="/dashboard" class="text-lg font-bold tracking-tight">Mymua</a>
      <div class="flex gap-2">
        <a href="/<%= user.username %>" target="_blank" class="text-xs text-zinc-500 hover:text-zinc-300 underline">View Page</a>
        <form method="POST" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="text-xs text-zinc-600 hover:text-red-400">Sign Out</button>
        </form>
      </div>
    </header>
    <!-- Mobile nav -->
    <div class="md:hidden flex overflow-x-auto gap-1 px-4 py-2 border-b border-zinc-800 text-xs">
      <a href="/dashboard" class="px-3 py-1.5 rounded-md <%= path === '/dashboard' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Overview</a>
      <a href="/dashboard/profile" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/profile' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Profile</a>
      <a href="/dashboard/services" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/services' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Services</a>
      <a href="/dashboard/gallery" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/gallery' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Gallery</a>
      <a href="/dashboard/testimonials" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/testimonials' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Reviews</a>
      <a href="/dashboard/social" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/social' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Links</a>
      <a href="/dashboard/templates" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/templates' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Templates</a>
      <a href="/dashboard/bookings" class="px-3 py-1.5 rounded-md <%= path === '/dashboard/bookings' ? 'bg-zinc-800 text-zinc-100' : 'text-zinc-500' %>">Bookings</a>
    </div>

    <!-- Content -->
    <main class="flex-1 p-4 md:p-6 overflow-y-auto">
      <div class="max-w-3xl mx-auto">
        <%- body %>
      </div>
    </main>
  </div>
</body>
</html>
