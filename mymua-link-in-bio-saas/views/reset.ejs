<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password — Mymua</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-dvh flex items-center justify-center p-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold tracking-tight">Mymua</h1>
      <p class="text-zinc-500 text-sm mt-1">Enter your new password</p>
    </div>
    <% if (error) { %><div class="mb-4 p-3 bg-red-900/30 border border-red-800 text-red-400 text-sm rounded-lg"><%= error %></div><% } %>
    <form method="POST" action="/reset/<%= token %>" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">New Password</label>
        <input type="password" name="password" required minlength="8" class="w-full px-4 py-3 bg-zinc-900 border border-zinc-800 rounded-lg text-sm focus:outline-none focus:border-zinc-600">
        <p class="text-zinc-600 text-xs mt-1">Minimum 8 characters</p>
      </div>
      <button type="submit" class="w-full py-3 bg-zinc-100 text-zinc-900 rounded-lg text-sm font-medium hover:bg-zinc-200">Reset Password</button>
    </form>
  </div>
</body>
</html>
