            <label class="f-label" for="full_name">Full Name <span>*</span></label>
            <input class="f-input" type="text" id="full_name" name="full_name" placeholder="Your full name" required autocomplete="name" />
          </div>
          <div>
            <label class="f-label" for="email">Email <span>*</span></label>
            <input class="f-input" type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email" />
          </div>
          <div>
            <label class="f-label" for="phone">Phone <span>*</span></label>
            <input class="f-input" type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required autocomplete="tel" />
          </div>
          <div>
            <label class="f-label" for="event_date">Event Date</label>
            <input class="f-input" type="date" id="event_date" name="event_date" min="<%= new Date().toISOString().split('T')[0] %>" />
          </div>
          <div>
            <label class="f-label" for="event_type">Event Type</label>
            <select class="f-select" id="event_type" name="event_type">
              <option value="" disabled selected>Select type</option>
              <option value="Sangeet">Sangeet</option>
              <option value="Cocktail">Cocktail Reception</option>
              <option value="Wedding Reception">Wedding Reception</option>
              <option value="Birthday">Birthday / Party</option>
              <option value="Corporate">Corporate Gala</option>
              <option value="Fashion Show">Fashion Show</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div>
            <label class="f-label" for="venue">Venue / Location</label>
            <input class="f-input" type="text" id="venue" name="venue" placeholder="e.g. The Grand, Mumbai" />
          </div>
          <div>
            <label class="f-label" for="guests">Guest Count</label>
            <select class="f-select" id="guests" name="guests">
              <option value="" disabled selected>Select size</option>
              <% for (let i = 1; i <= 50; i++) { %><option value="<%= i %>"><%= i %></option><% } %>
              <option value="50+">50+</option>
            </select>
          </div>
          <div>
            <label class="f-label" for="message">Message</label>
            <textarea class="f-textarea" id="message" name="message" placeholder="Tell me about your event, theme, and the look you imagine..." rows="3"></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-gold mt-5 w-full justify-center" style="padding:15px 28px;">Book Now</button>
      </form>
    </div>
  </section>

