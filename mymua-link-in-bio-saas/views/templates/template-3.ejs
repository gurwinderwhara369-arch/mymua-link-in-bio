<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FAFAFA" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content="<%= user.bio ? user.bio.slice(0, 160) : 'Editorial bridal makeup by ' + user.name + ' — modern. bold. unforgettable.' %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet" />
    <title><%= user.name %> — Editorial Bridal</title>
    <link rel="stylesheet" href="/css/brochure2.css" />
  </head>
  <body class="bg-[#FAFAFA] text-[#1A1A1A] min-h-dvh overflow-x-hidden" style="font-family: 'Outfit', sans-serif;">

    <!-- ====== HEADER ====== -->
    <header id="editorial-header" class="editorial-header">
      <div class="flex items-center justify-between max-w-[480px] mx-auto">
        <span class="text-sm font-bold tracking-[0.15em] uppercase text-white" style="font-family: 'Syne', sans-serif;"><%= user.name %></span>
        <a href="#contact" class="text-xs font-medium tracking-wider uppercase px-4 py-2 border text-white border-white/30 hover:bg-white hover:text-[#1A1A1A] transition-all" style="font-family: 'Outfit', sans-serif;">Book</a>
      </div>
    </header>

    <!-- ====== HERO ====== -->
    <section class="hero-section">
      <div class="hero-bg">
        <img src="<%= user.photo || 'https://images.unsplash.com/photo-1586297135537-94bc9ba060aa?w=800&q=85' %>" alt="Editorial bridal makeup" loading="eager" />
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div data-reveal>
          <p class="text-xs tracking-[0.2em] uppercase text-[#FF6B6B] font-medium mb-2" style="font-family: 'Outfit', sans-serif;">Editorial Bridal Makeup</p>
          <h1 class="hero-name"><%= user.name %></h1>
          <p class="hero-title"><%= user.title || 'Redefining bridal beauty editorial' %></p>
          <a href="#contact" class="inline-flex items-center gap-2 mt-6 text-sm font-medium tracking-wider uppercase px-6 py-3 border-2 border-[#FF6B6B] text-[#FF6B6B] hover:bg-[#FF6B6B] hover:text-white transition-all" style="font-family: 'Outfit', sans-serif;">
            Book Now
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ====== STATS ====== -->
    <section class="py-8 border-b border-[#E8E8E8]">
      <div class="stat-scroll">
        <div class="stat-item"><p class="stat-number">8+</p><p class="stat-label">Years</p></div>
        <div class="stat-item"><p class="stat-number">350+</p><p class="stat-label">Brides</p></div>
        <div class="stat-item"><p class="stat-number">4.9</p><p class="stat-label">Rating</p></div>
        <div class="stat-item"><p class="stat-number">15+</p><p class="stat-label">Countries</p></div>
        <div class="stat-item"><p class="stat-number">100+</p><p class="stat-label">Editorials</p></div>
      </div>
    </section>

    <!-- ====== ABOUT ====== -->
    <section class="px-5 py-12 border-b border-[#E8E8E8]">
      <div class="max-w-[480px] mx-auto" data-reveal>
        <p class="section-label">About</p>
        <h2 class="section-heading mt-3">Editorial<br />Vision</h2>
        <div class="mt-5 space-y-3 text-sm text-[#888] leading-relaxed text-balance" style="font-family: 'Outfit', sans-serif;">
          <p><%= user.bio || 'With a background in fashion editorial and haute couture, I bring a photographer\'s eye to every bridal look.' %></p>
        </div>
      </div>
    </section>

    <!-- ====== SERVICES ====== -->
    <section class="px-5 py-12 border-b border-[#E8E8E8]">
      <div class="max-w-[480px] mx-auto">
        <div data-reveal>
          <p class="section-label">Services</p>
          <h2 class="section-heading mt-3">Investment</h2>
        </div>
        <% if (user.services && user.services.length) { %>
        <div class="flex flex-col gap-2 mt-6" data-reveal-stagger>
          <% user.services.forEach(function(s) { %>
          <div class="service-card-ed flex items-center justify-between p-4">
            <div><h3 class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;"><%= s.name %></h3><% if (s.desc) { %><p class="text-xs text-[#888] mt-0.5"><%= s.desc %></p><% } %></div>
            <p class="text-base font-bold text-[#FF6B6B]" style="font-family: 'Syne', sans-serif;"><%= s.price %></p>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="flex flex-col gap-2 mt-6" data-reveal-stagger>
          <div class="service-card-ed flex items-center justify-between p-4">
            <div><h3 class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">BRIDAL</h3><p class="text-xs text-[#888] mt-0.5">Full look + trial</p></div>
            <p class="text-base font-bold text-[#FF6B6B]" style="font-family: 'Syne', sans-serif;">₹18K+</p>
          </div>
          <div class="service-card-ed flex items-center justify-between p-4">
            <div><h3 class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">ENGAGEMENT</h3><p class="text-xs text-[#888] mt-0.5">Roka & sangeet</p></div>
            <p class="text-base font-bold text-[#FF6B6B]" style="font-family: 'Syne', sans-serif;">₹12K+</p>
          </div>
          <div class="service-card-ed flex items-center justify-between p-4">
            <div><h3 class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">RECEPTION</h3><p class="text-xs text-[#888] mt-0.5">Evening glam</p></div>
            <p class="text-base font-bold text-[#FF6B6B]" style="font-family: 'Syne', sans-serif;">₹15K+</p>
          </div>
          <div class="service-card-ed flex items-center justify-between p-4">
            <div><h3 class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">EDITORIAL</h3><p class="text-xs text-[#888] mt-0.5">Fashion / print</p></div>
            <p class="text-base font-bold text-[#FF6B6B]" style="font-family: 'Syne', sans-serif;">₹25K+</p>
          </div>
          <div class="service-card-ed flex items-center justify-between p-4">
            <div><h3 class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">AIRBRUSH</h3><p class="text-xs text-[#888] mt-0.5">Flawless finish</p></div>
            <p class="text-base font-bold text-[#FF6B6B]" style="font-family: 'Syne', sans-serif;">₹20K+</p>
          </div>
        </div>
        <% } %>
      </div>
    </section>

    <!-- ====== GALLERY ====== -->
    <section class="py-12 border-b border-[#E8E8E8]">
      <div class="px-5 max-w-[480px] mx-auto" data-reveal>
        <p class="section-label">Portfolio</p>
        <h2 class="section-heading mt-3">Featured<br />Work</h2>
      </div>
      <% if (user.gallery && user.gallery.length) { %>
      <div id="gallery-grid-ed" class="gallery-grid-ed mt-6">
        <% user.gallery.forEach(function(img, i) { %>
        <div class="g-item <%= i === 0 ? 'wide' : '' %>" data-src="<%= img.url %>" data-alt="<%= img.alt || 'Bridal makeup' %>">
          <img src="<%= img.url %>" alt="<%= img.alt || 'Bridal makeup' %>" loading="lazy" />
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div id="gallery-grid-ed" class="gallery-grid-ed mt-6">
        <div class="g-item wide" data-src="https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=1200&q=85" data-alt="Bridal editorial">
          <img src="https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=600&q=80" alt="Bridal editorial" loading="lazy" />
        </div>
        <div class="g-item" data-src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=800&q=85" data-alt="Soft glam">
          <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=400&q=80" alt="Soft glam" loading="lazy" />
        </div>
        <div class="g-item" data-src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=800&q=85" data-alt="Makeup detail">
          <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=400&q=80" alt="Makeup detail" loading="lazy" />
        </div>
        <div class="g-item" data-src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=800&q=85" data-alt="Traditional elegance">
          <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=400&q=80" alt="Traditional elegance" loading="lazy" />
        </div>
        <div class="g-item tall" data-src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=800&q=85" data-alt="Full transformation">
          <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400&q=80" alt="Full transformation" loading="lazy" />
        </div>
        <div class="g-item" data-src="https://images.unsplash.com/photo-1597225244660-1cd128c6888a?w=1200&q=85" data-alt="Bridal portrait">
          <img src="https://images.unsplash.com/photo-1597225244660-1cd128c6888a?w=600&q=80" alt="Bridal portrait" loading="lazy" />
        </div>
        <div class="g-item" data-src="https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=800&q=85" data-alt="BTS bridal">
          <img src="https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=400&q=80" alt="BTS bridal" loading="lazy" />
        </div>
      </div>
      <% } %>
    </section>

    <!-- ====== TESTIMONIALS ====== -->
    <section class="py-12 border-b border-[#E8E8E8]">
      <div class="px-5 max-w-[480px] mx-auto" data-reveal>
        <p class="section-label">Kind Words</p>
        <h2 class="section-heading mt-3">Press &<br />Brides</h2>
      </div>
      <% if (user.testimonials && user.testimonials.length) { %>
      <div class="testimonial-scroll mt-6">
        <% user.testimonials.forEach(function(t) { %>
        <div class="t-card p-5">
          <p class="text-sm text-[#888] leading-relaxed italic text-balance" style="font-family: 'Outfit', sans-serif;">"<%= t.text %>"</p>
          <div class="flex gap-0.5 mt-3">
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <div class="mt-3 pt-3 border-t border-[#E8E8E8] flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-[#FF6B6B]/20 flex items-center justify-center text-[#FF6B6B] text-xs font-bold" style="font-family: 'Syne', sans-serif;"><%= t.name.charAt(0) %></div>
            <div>
              <p class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;"><%= t.name %></p>
              <p class="text-xs text-[#888]"><%= t.event || 'Bride' %></p>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="testimonial-scroll mt-6">
        <div class="t-card p-5">
          <p class="text-sm text-[#888] leading-relaxed italic text-balance" style="font-family: 'Outfit', sans-serif;">
            "Zara doesn't just do makeup — she creates art. My bridal shoot looked like a Vogue editorial."
          </p>
          <div class="flex gap-0.5 mt-3">
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <div class="mt-3 pt-3 border-t border-[#E8E8E8] flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-[#FF6B6B]/20 flex items-center justify-center text-[#FF6B6B] text-xs font-bold" style="font-family: 'Syne', sans-serif;">M</div>
            <div>
              <p class="text-sm font-semibold text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">MIRA JOSHI</p>
              <p class="text-xs text-[#888]">Bride · Goa Wedding</p>
            </div>
          </div>
        </div>
        <div class="t-card p-5">
          <p class="text-sm text-[#888] leading-relaxed italic text-balance" style="font-family: 'Outfit', sans-serif;">
            "Her editorial eye is unmatched. Every shot was magazine-ready. Absolute professional."
          </p>
          <div class="flex gap-0.5 mt-3">
            <svg class="w-3.5 h-3.5 text-[#FF6B6B]" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
