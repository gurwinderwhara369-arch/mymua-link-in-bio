    </section>

    <!-- ====== AVAILABILITY ====== -->
    <section id="availability" class="px-5 py-12 border-t border-[#E8E8E8]">
      <div class="max-w-[480px] mx-auto">
        <div data-reveal>
          <p class="text-xs tracking-[0.2em] uppercase text-[#FF6B6B] font-medium" style="font-family: 'Outfit', sans-serif;">Availability</p>
          <h2 class="text-2xl font-bold mt-2 uppercase tracking-[-0.02em] text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">Open Dates</h2>
          <p class="text-sm text-[#888] mt-2" style="font-family: 'Outfit', sans-serif;">Claim your date before it's gone</p>
        </div>
        <div id="calendar-3" class="mt-6" data-reveal></div>
        <p class="text-xs text-[#888]/50 text-center mt-3" style="font-family: 'Outfit', sans-serif;">🟢 Available &nbsp;•&nbsp; 🔴 Booked &nbsp;•&nbsp; ⚪ Past</p>
      </div>
    </section>

    <!-- ====== BOOKING FORM ====== -->
    <section id="booking" class="px-5 py-12" style="background: #F5F5F5;">
      <div class="max-w-[480px] mx-auto">
        <div data-reveal>
          <p class="text-xs tracking-[0.2em] uppercase text-[#FF6B6B] font-medium" style="font-family: 'Outfit', sans-serif;">Book Now</p>
          <h2 class="text-2xl font-bold mt-2 uppercase tracking-[-0.02em] text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;">Reserve Your Date</h2>
          <p class="text-sm text-[#888] mt-2" style="font-family: 'Outfit', sans-serif;">Submit this and we'll confirm within 2 hours</p>
        </div>

        <% if (bookingStatus === 'success') { %>
        <div class="mt-6 p-4 bg-green-50 border border-green-200 text-center" data-reveal>
          <p class="text-[#1A1A1A] font-medium" style="font-family: 'Outfit', sans-serif;">✓ Booking request sent!</p>
          <p class="text-xs text-[#888] mt-1" style="font-family: 'Outfit', sans-serif;">The artist will contact you soon.</p>
        </div>
        <% } else if (bookingStatus && bookingStatus.startsWith('error')) { %>
        <div class="mt-6 p-4 bg-red-50 border border-red-200 text-center" data-reveal>
          <p class="text-red-600 font-medium" style="font-family: 'Outfit', sans-serif;">✗ <%= bookingStatus.replace('error=', '') %></p>
        </div>
        <% } %>
        <form action="/booking/<%= username %>" method="POST" class="mt-6 space-y-4" data-reveal>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Full Name <span class="text-[#FF6B6B]">*</span></label>
            <input type="text" name="name" required
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;"
              placeholder="e.g. Ananya Sharma" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Phone Number <span class="text-[#FF6B6B]">*</span></label>
            <input type="tel" name="phone" required
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;"
              placeholder="e.g. +91 98765 43210" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Email</label>
            <input type="email" name="email"
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;"
              placeholder="e.g. ananya@email.com" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Your Location / City</label>
            <input type="text" name="location"
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;"
              placeholder="e.g. Mumbai, Maharashtra" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Service Interested In</label>
            <select name="service"
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;">
              <option value="">Select a service...</option>
              <% if (user.services && user.services.length) { %>
              <% user.services.forEach(function(s) { %>
              <option value="<%= s.name %>"><%= s.name %> — <%= s.price %></option>
              <% }) %>
              <% } else { %>
              <option value="bridal">Bridal — ₹18K+</option>
              <option value="engagement">Engagement — ₹12K+</option>
              <option value="reception">Reception — ₹15K+</option>
              <option value="editorial">Editorial — ₹25K+</option>
              <option value="airbrush">Airbrush — ₹20K+</option>
              <option value="custom">Custom Package</option>
              <% } %>
            </select>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Guests</label>
              <input type="number" name="guests" min="1"
                class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
                style="font-family: 'Outfit', sans-serif; border-radius: 0;"
                placeholder="50" />
            </div>
            <div>
              <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Event Date</label>
              <input type="date" name="event_date"
                class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
                style="font-family: 'Outfit', sans-serif; border-radius: 0;" />
            </div>
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Travel Required?</label>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="travel" value="yes" class="w-4 h-4 accent-[#FF6B6B]" />
                <span class="text-sm text-[#888]" style="font-family: 'Outfit', sans-serif;">Yes</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="travel" value="no" checked class="w-4 h-4 accent-[#FF6B6B]" />
                <span class="text-sm text-[#888]" style="font-family: 'Outfit', sans-serif;">No</span>
              </label>
            </div>
          </div>

          <div class="travel-destination" style="display:none;">
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Destination / Event Location</label>
            <input type="text" name="destination"
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;"
              placeholder="e.g. Udaipur, Rajasthan" />
          </div>

          <div>
            <label class="block text-[10px] tracking-[0.15em] uppercase text-[#888] mb-1 font-medium" style="font-family: 'Outfit', sans-serif;">Additional Notes</label>
            <textarea name="notes" rows="3"
              class="w-full px-4 py-3 bg-white border-0 text-sm text-[#1A1A1A] outline-none shadow-sm focus:shadow-md transition-shadow resize-none"
              style="font-family: 'Outfit', sans-serif; border-radius: 0;"
              placeholder="Any specific requests, themes, or questions..."></textarea>
          </div>

          <button type="submit"
            class="w-full py-3.5 bg-[#1A1A1A] text-white text-sm tracking-[0.15em] uppercase font-semibold border-none cursor-pointer transition-all active:scale-[0.97] hover:bg-[#FF6B6B]"
            style="font-family: 'Outfit', sans-serif; border-radius: 0;">
            Send Booking Request
          </button>
        </form>
      </div>
    </section>

    <!-- ====== FOOTER ====== -->
    <footer class="border-t border-[#E8E8E8] px-5 py-8 text-center safe-bottom">
      <div class="max-w-[480px] mx-auto">
        <p class="text-sm font-bold tracking-[0.15em] uppercase text-[#1A1A1A]" style="font-family: 'Syne', sans-serif;"><%= user.name %></p>
        <p class="text-[10px] text-[#888] tracking-[0.2em] uppercase mt-1"><%= user.title || 'Editorial Bridal Makeup' %></p>
        <div class="flex items-center justify-center gap-3 mt-4">
          <% if (user.social && user.social.instagram) { %>
          <a href="https://instagram.com/<%= user.social.instagram %>" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center border border-[#E8E8E8] text-[#888] hover:text-[#FF6B6B] hover:border-[#FF6B6B] transition-all" aria-label="Instagram">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 016.11 2.525c.636-.247 1.363-.416 2.427-.465C8.83 2.013 9.075 2 12.315 2z"/></svg>
          </a>
          <% } %>
          <% if (user.social && user.social.email) { %>
          <a href="mailto:<%= user.social.email %>" class="w-8 h-8 flex items-center justify-center border border-[#E8E8E8] text-[#888] hover:text-[#FF6B6B] hover:border-[#FF6B6B] transition-all" aria-label="Email">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75"/></svg>
          </a>
          <% } %>
        </div>
        <p class="text-[10px] text-[#888]/50 tracking-wider mt-4">&copy; 2026 <%= user.name %></p>
      </div>
    </footer>

    <script src="/js/brochure2.js"></script>
  </body>
</html>