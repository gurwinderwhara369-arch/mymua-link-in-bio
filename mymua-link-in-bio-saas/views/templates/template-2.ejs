      <!-- ====== AVAILABILITY ====== -->
      <section id="availability" class="px-4 py-12" style="background: rgba(212,163,115,0.04);">
        <div class="max-w-[480px] mx-auto">
          <div data-reveal>
            <p class="text-xs tracking-[0.25em] uppercase text-[#D4A373] font-medium" style="font-family: 'Cormorant Infant', serif;">Availability</p>
            <h3 class="text-2xl font-bold mt-2 gradient-text-rose" style="font-family: 'Cormorant Infant', serif;">Open Dates</h3>
            <p class="text-sm text-[#8C7D79]/60 mt-2" style="font-family: 'Cormorant Infant', serif;">Secure your date before someone else does</p>
          </div>
          <div id="calendar-2" class="mt-6" data-reveal></div>
          <p class="text-xs text-[#8C7D79]/40 text-center mt-3 font-medium" style="font-family: 'Cormorant Infant', serif;">🟢 Available &nbsp;•&nbsp; 🔴 Booked &nbsp;•&nbsp; ⚪ Past</p>
        </div>
      </section>

      <!-- ====== BOOKING FORM ====== -->
      <section id="booking" class="px-4 py-12">
        <div class="max-w-[480px] mx-auto">
          <div data-reveal>
            <p class="text-xs tracking-[0.25em] uppercase text-[#D4A373] font-medium" style="font-family: 'Cormorant Infant', serif;">Book Now</p>
            <h3 class="text-2xl font-bold mt-2 gradient-text-rose" style="font-family: 'Cormorant Infant', serif;">Reserve Your Date</h3>
            <p class="text-sm text-[#8C7D79]/60 mt-2" style="font-family: 'Cormorant Infant', serif;">Fill this in and we'll reply within 2 hours</p>
          </div>

          <% if (bookingStatus === 'success') { %>
          <div class="mt-6 p-4 bg-green-50 border border-[#D4A373]/30 rounded-lg text-center" data-reveal>
            <p class="text-[#3D3533] font-medium" style="font-family: 'Cormorant Infant', serif;">✓ Booking request sent!</p>
            <p class="text-xs text-[#8C7D79] mt-1" style="font-family: 'Cormorant Infant', serif;">The artist will contact you soon.</p>
          </div>
          <% } else if (bookingStatus && bookingStatus.startsWith('error')) { %>
          <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-lg text-center" data-reveal>
            <p class="text-red-600 font-medium" style="font-family: 'Cormorant Infant', serif;">✗ <%= bookingStatus.replace('error=', '') %></p>
          </div>
          <% } %>
          <form action="/booking/<%= username %>" method="POST" class="mt-6 space-y-4" data-reveal>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Full Name <span class="text-[#D4A373]">*</span></label>
              <input type="text" name="name" required
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                style="font-family: 'Cormorant Infant', serif;"
                placeholder="e.g. Ananya Sharma" />
            </div>

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Phone Number <span class="text-[#D4A373]">*</span></label>
              <input type="tel" name="phone" required
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                style="font-family: 'Cormorant Infant', serif;"
                placeholder="e.g. +91 98765 43210" />
            </div>

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Email</label>
              <input type="email" name="email"
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                style="font-family: 'Cormorant Infant', serif;"
                placeholder="e.g. ananya@email.com" />
            </div>

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Your Location / City</label>
              <input type="text" name="location"
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                style="font-family: 'Cormorant Infant', serif;"
                placeholder="e.g. Mumbai, Maharashtra" />
            </div>

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Service Interested In</label>
              <select name="service"
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                style="font-family: 'Cormorant Infant', serif;">
                <option value="">Select a service...</option>
                <% (user.services || []).forEach(function(s) { %>
                <option value="<%= s.name %>"><%= s.name %> — <%= s.price %></option>
                <% }) %>
              </select>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Guests</label>
                <input type="number" name="guests" min="1"
                  class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                  style="font-family: 'Cormorant Infant', serif;"
                  placeholder="50" />
              </div>
              <div>
                <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Event Date</label>
                <input type="date" name="event_date"
                  class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                  style="font-family: 'Cormorant Infant', serif;" />
              </div>
            </div>

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Travel Required?</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="travel" value="yes" class="w-4 h-4 accent-[#D4A373]" />
                  <span class="text-sm text-[#8C7D79]" style="font-family: 'Cormorant Infant', serif;">Yes</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="travel" value="no" checked class="w-4 h-4 accent-[#D4A373]" />
                  <span class="text-sm text-[#8C7D79]" style="font-family: 'Cormorant Infant', serif;">No</span>
                </label>
              </div>
            </div>

            <div class="travel-destination" style="display:none;">
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Destination / Event Location</label>
              <input type="text" name="destination"
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all"
                style="font-family: 'Cormorant Infant', serif;"
                placeholder="e.g. Udaipur, Rajasthan" />
            </div>

            <div>
              <label class="block text-xs tracking-[0.15em] uppercase text-[#8C7D79]/70 mb-1.5" style="font-family: 'Cormorant Infant', serif;">Additional Notes</label>
              <textarea name="notes" rows="3"
                class="w-full px-4 py-3 bg-white/60 border border-[#D4A373]/20 focus:border-[#D4A373] text-sm text-[#3D3533] outline-none transition-all resize-none"
                style="font-family: 'Cormorant Infant', serif;"
                placeholder="Any specific requests, themes, or questions..."></textarea>
            </div>

            <button type="submit"
              class="w-full py-3.5 bg-gradient-to-r from-[#D4A373] to-[#C4956A] text-white text-sm tracking-[0.15em] uppercase font-medium border-none cursor-pointer transition-all active:scale-[0.98]"
              style="font-family: 'Cormorant Infant', serif;">
              Send Booking Request
            </button>
          </form>
        </div>
      </section>

      <!-- ====== FOOTER ====== -->
      <footer class="mt-auto px-4 py-10 text-center safe-bottom">
        <div class="max-w-[480px] mx-auto flex flex-col items-center gap-4">
          <div class="floral-divider w-full">
            <svg class="w-5 h-5 text-[#D4A373]/25" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg>
          </div>
          <div class="flex flex-col items-center gap-1">
            <p class="text-lg font-script gradient-text-rose" style="font-family: 'Great Vibes', cursive;"><%= user.name %></p>
            <p class="text-xs text-[#8C7D79]/40 tracking-[0.2em] uppercase" style="font-family: 'Cormorant Infant', serif;"><%= user.title %></p>
          </div>
          <div class="flex items-center gap-4">
            <% if (user.social.instagram) { %>
            <a href="https://instagram.com/<%= user.social.instagram %>" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-[#FAF0EA] flex items-center justify-center text-[#8C7D79]/50 hover:text-[#D4A373] transition-colors" aria-label="Instagram">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 016.11 2.525c.636-.247 1.363-.416 2.427-.465C8.83 2.013 9.075 2 12.315 2z"/></svg>
            </a>
            <% } %>
            <% if (user.social.email) { %>
            <a href="mailto:<%= user.social.email %>" class="w-8 h-8 rounded-full bg-[#FAF0EA] flex items-center justify-center text-[#8C7D79]/50 hover:text-[#D4A373] transition-colors" aria-label="Email">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </a>
            <% } %>
            <% if (user.social.phone) { %>
            <a href="tel:+<%= user.social.phone %>" class="w-8 h-8 rounded-full bg-[#FAF0EA] flex items-center justify-center text-[#8C7D79]/50 hover:text-[#D4A373] transition-colors" aria-label="Phone">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </a>
            <% } %>
          </div>
          <p class="text-[10px] text-[#8C7D79]/30 tracking-wider" style="font-family: 'Cormorant Infant', serif;">&copy; 2026 <%= user.name %>. All rights reserved.</p>
        </div>
      </footer>

    </div>

    <script src="/js/brochure.js"></script>
  </body>
</html>
