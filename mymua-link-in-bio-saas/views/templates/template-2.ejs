                  <label class="whatsapp-form-label" for="wa-inquiry">Inquiry Type</label>
                  <select id="wa-inquiry" class="whatsapp-form-input">
                    <option value="">Select type...</option>
                    <option value="Availability Check">Availability Check</option>
                    <option value="Booking Inquiry">Booking Inquiry</option>
                    <option value="Pricing Inquiry">Pricing Inquiry</option>
                    <option value="General Question">General Question</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div class="whatsapp-field">
                  <label class="whatsapp-form-label" for="wa-date">Event Date</label>
                  <input type="date" id="wa-date" class="whatsapp-form-input" />
                </div>
                <div class="whatsapp-field">
                  <label class="whatsapp-form-label">Services Interested In</label>
                  <div class="flex flex-wrap gap-2 mt-1">
                    <span class="service-chip" role="button" tabindex="0">Bridal Makeup</span>
                    <span class="service-chip" role="button" tabindex="0">Engagement Makeup</span>
                    <span class="service-chip" role="button" tabindex="0">Reception Makeup</span>
                    <span class="service-chip" role="button" tabindex="0">Trial Makeup</span>
                    <span class="service-chip" role="button" tabindex="0">Airbrush Makeup</span>
                    <span class="service-chip" role="button" tabindex="0">Party Makeup</span>
                    <span class="service-chip" role="button" tabindex="0">HD Makeup</span>
                  </div>
                </div>
                <div class="whatsapp-field">
                  <label class="whatsapp-form-label" for="wa-notes">Additional Notes</label>
                  <textarea id="wa-notes" class="whatsapp-form-input min-h-[80px] resize-none" placeholder="Any specific requests or questions..."></textarea>
                </div>
                <button type="submit" class="btn w-full h-12 rounded-xl border-2 border-[#D4A373] bg-[#D4A373] text-white text-base hover:bg-[#C4956A] hover:border-[#C4956A] font-medium shadow-lg shadow-[#D4A373]/20 active:scale-[0.97] transition-all" style="font-family: 'Cormorant Infant', serif;">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
                  Send via WhatsApp
                </button>
              </form>
            </div>
          </details>
          <% } %>

          <% if (user.social.instagram) { %>
          <a href="https://instagram.com/<%= user.social.instagram %>" target="_blank" rel="noopener noreferrer" class="link-item flex items-center gap-4 p-4 rounded-2xl bg-[#FAF0EA]/50 border border-[#E8B4B8]/20 active:scale-[0.97] transition-all">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-pink-500/20 via-purple-500/20 to-orange-500/20 flex items-center justify-center flex-none">
              <svg class="w-5 h-5 text-pink-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 016.11 2.525c.636-.247 1.363-.416 2.427-.465C8.83 2.013 9.075 2 12.315 2z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-[#3D3533]" style="font-family: 'Cormorant Infant', serif;">Instagram</h3>
              <p class="text-sm text-[#8C7D79]/60" style="font-family: 'Cormorant Infant', serif;">@<%= user.social.instagram %></p>
            </div>
            <svg class="w-5 h-5 text-[#8C7D79]/30 flex-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
          <% } %>

          <% if (user.social.email) { %>
          <a href="mailto:<%= user.social.email %>" class="link-item flex items-center gap-4 p-4 rounded-2xl bg-[#FAF0EA]/50 border border-[#E8B4B8]/20 active:scale-[0.97] transition-all">
            <div class="w-12 h-12 rounded-xl bg-blue-500/15 flex items-center justify-center flex-none">
              <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-[#3D3533]" style="font-family: 'Cormorant Infant', serif;">Email</h3>
              <p class="text-sm text-[#8C7D79]/60" style="font-family: 'Cormorant Infant', serif;"><%= user.social.email %></p>
            </div>
            <svg class="w-5 h-5 text-[#8C7D79]/30 flex-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
