<!doctype html>
<html lang="en" data-theme="cupcake">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FDF8F4" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content="<%= user.bio ? user.bio.slice(0, 160) : 'Premium bridal makeup artistry' %>" />
    <meta name="format-detection" content="telephone=yes" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Infant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Great+Vibes&display=swap" rel="stylesheet" />
    <title><%= user.name %> — Bridal Makeup Artist</title>
    <link rel="stylesheet" href="/css/brochure.css" />
  </head>
  <body class="bg-[#FDF8F4] text-[#3D3533] min-h-dvh overflow-x-hidden" style="font-family: 'Cormorant Infant', Georgia, serif;">

    <!-- Floating rose petals -->
    <div id="petals-container" aria-hidden="true"></div>

    <!-- Floating gold sparkles -->
    <div id="sparkles-container" aria-hidden="true">
      <svg class="sparkle s1" width="24" height="24" viewBox="0 0 100 100"><use href="#sparkle-shape"/></svg>
      <svg class="sparkle s2" width="16" height="16" viewBox="0 0 100 100"><use href="#sparkle-shape"/></svg>
      <svg class="sparkle s3" width="20" height="20" viewBox="0 0 100 100"><use href="#sparkle-shape"/></svg>
      <svg class="sparkle s4" width="14" height="14" viewBox="0 0 100 100"><use href="#sparkle-shape"/></svg>
      <svg class="sparkle s5" width="18" height="18" viewBox="0 0 100 100"><use href="#sparkle-shape"/></svg>
      <svg class="sparkle s6" width="12" height="12" viewBox="0 0 100 100"><use href="#sparkle-shape"/></svg>
    </div>

    <svg hidden><defs><path id="sparkle-shape" d="M50,10 L53.75,46.25 L90,50 L53.75,53.75 L50,90 L46.25,53.75 L10,50 L46.25,46.25z" fill="#D4A373"/></defs></svg>

    <!-- Background texture overlay -->
    <div class="bg-lace-overlay" aria-hidden="true"></div>

    <!-- Ambient glow blobs -->
    <div class="ambient-blob blob-1" aria-hidden="true"></div>
    <div class="ambient-blob blob-2" aria-hidden="true"></div>
    <div class="ambient-blob blob-3" aria-hidden="true"></div>

    <!-- ====== FLOATING WHATSAPP BUTTON ====== -->
    <a href="https://wa.me/<%= user.social.whatsapp || '919999999999' %>?text=Hi%20<%= encodeURIComponent(user.name) %>%20I'd%20love%20to%20inquire%20about%20bridal%20makeup%20services." target="_blank" rel="noopener noreferrer"
       class="fab" aria-label="Chat on WhatsApp">
      <div class="pulse-ring"></div>
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span class="fab-tooltip">Chat on WhatsApp</span>
    </a>

    <!-- ====== HEADER ====== -->
    <header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 safe-top"
            style="background: color-mix(in oklab, #FDF8F4 70%, transparent); backdrop-filter: blur(20px);">
      <div class="max-w-[480px] mx-auto flex items-center justify-between h-14 px-4">
        <span class="text-lg font-script gradient-text-rose" style="font-family: 'Great Vibes', cursive; font-size: 1.35rem;"><%= user.name %></span>
        <nav class="flex items-center gap-1" aria-label="Quick navigation">
          <a href="#gallery" class="btn btn-ghost btn-xs font-medium tracking-wider text-[#8C7D79] hover:text-[#3D3533] transition-colors" style="font-family: 'Cormorant Infant', serif; font-size: 0.875rem;">Gallery</a>
          <a href="#services" class="btn btn-ghost btn-xs font-medium tracking-wider text-[#8C7D79] hover:text-[#3D3533] transition-colors" style="font-family: 'Cormorant Infant', serif; font-size: 0.875rem;">Services</a>
          <a href="#contact" class="btn btn-ghost btn-xs font-medium tracking-wider text-[#E8B4B8] font-semibold transition-colors" style="font-family: 'Cormorant Infant', serif; font-size: 0.875rem;">Contact</a>
        </nav>
      </div>
    </header>

    <!-- ====== MAIN WRAPPER ====== -->
    <div class="flex flex-col min-h-dvh max-w-[480px] mx-auto relative">

      <!-- ====== HERO ====== -->
      <section id="hero" class="relative pt-24 pb-12 px-4 overflow-hidden">
        <div class="relative flex flex-col items-center text-center gap-5" data-reveal>
          <div class="relative">
            <div class="w-28 h-28 rounded-full overflow-hidden ring-[4px] ring-[#D4A373]/40 ring-offset-[6px] ring-offset-[#FDF8F4] shadow-2xl shadow-[#D4A373]/20">
              <img src="<%= user.photo || 'https://images.unsplash.com/photo-1586297135537-94bc9ba060aa?w=400&q=80' %>" alt="<%= user.name %> — Bridal Makeup Artist" class="w-full h-full object-cover" loading="eager" />
            </div>
            <div class="absolute -bottom-1 -right-1 w-8 h-8 bg-[#D4A373] rounded-full flex items-center justify-center shadow-lg shadow-[#D4A373]/40 animate-float">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-center gap-2">
              <div class="w-6 h-px bg-[#D4A373]/50"></div>
              <span class="text-[10px] uppercase tracking-[0.2em] text-[#D4A373] font-semibold" style="font-family: 'Cormorant Infant', serif;"><%= user.title %></span>
              <div class="w-6 h-px bg-[#D4A373]/50"></div>
            </div>
            <h1 class="font-script text-4xl md:text-5xl text-[#3D3533] leading-[1.1]" style="font-family: 'Great Vibes', cursive;">
              <%= user.name %>
            </h1>
            <p class="text-lg text-[#8C7D79] max-w-xs mx-auto leading-relaxed text-balance italic" style="font-family: 'Cormorant Infant', serif;">
              Every bride deserves to feel<br />as beautiful as her love story.
            </p>
          </div>

          <% if (user.location) { %>
          <div class="flex items-center justify-center gap-1.5 text-sm text-[#8C7D79]/70">
            <svg class="w-3.5 h-3.5 text-[#D4A373]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            <span style="font-family: 'Cormorant Infant', serif;"><%= user.location %></span>
          </div>
          <% } %>

          <div class="flex items-center justify-center gap-8 py-2">
            <div class="flex flex-col items-center">
              <span class="text-2xl font-bold text-[#D4A373]" style="font-family: 'Great Vibes', cursive; font-size: 2rem;">10+</span>
              <span class="text-[10px] uppercase tracking-[0.15em] text-[#8C7D79] font-medium" style="font-family: 'Cormorant Infant', serif;">Years</span>
            </div>
            <div class="w-px h-10 bg-gradient-to-b from-transparent via-[#E8B4B8]/30 to-transparent"></div>
            <div class="flex flex-col items-center">
              <span class="text-2xl font-bold text-[#D4A373]" style="font-family: 'Great Vibes', cursive; font-size: 2rem;">400+</span>
              <span class="text-[10px] uppercase tracking-[0.15em] text-[#8C7D79] font-medium" style="font-family: 'Cormorant Infant', serif;">Brides</span>
            </div>
            <div class="w-px h-10 bg-gradient-to-b from-transparent via-[#E8B4B8]/30 to-transparent"></div>
            <div class="flex flex-col items-center">
              <span class="text-2xl font-bold text-[#D4A373]" style="font-family: 'Great Vibes', cursive; font-size: 2rem;">4.9</span>
              <span class="text-[10px] uppercase tracking-[0.15em] text-[#8C7D79] font-medium" style="font-family: 'Cormorant Infant', serif;">Rating</span>
            </div>
          </div>

          <div class="flex gap-1" aria-label="5 out of 5 stars">
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>

          <a href="#contact" class="btn h-12 min-w-[200px] rounded-full border-2 border-[#D4A373] bg-[#D4A373] text-white text-base hover:bg-[#C4956A] hover:border-[#C4956A] shadow-lg shadow-[#D4A373]/25 active:scale-[0.97] transition-all font-medium tracking-wider" style="font-family: 'Cormorant Infant', serif;">
            Book Your Trial
          </a>
        </div>
      </section>

      <!-- ====== FLORAL DIVIDER ====== -->
      <div class="floral-divider px-8 py-3">
        <svg class="w-6 h-6 text-[#D4A373]/40 animate-rose-float" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg>
      </div>

      <!-- ====== ABOUT ====== -->
      <section id="about" class="px-4 py-8">
        <div class="flex flex-col gap-4" data-reveal>
          <div class="flex items-center gap-3">
            <div class="w-8 h-px bg-gradient-to-r from-[#D4A373]/60 to-transparent"></div>
            <span class="text-[10px] uppercase tracking-[0.2em] text-[#D4A373] font-semibold" style="font-family: 'Cormorant Infant', serif;">About</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#3D3533] leading-[1.1] text-balance" style="font-family: 'Cormorant Infant', serif;">
            The Art of<br />Bridal Beauty
          </h2>
          <div class="flex flex-col gap-4 text-base md:text-lg text-[#8C7D79] leading-relaxed" style="font-family: 'Cormorant Infant', serif;">
            <% if (user.bio) { %>
            <p class="text-balance"><%= user.bio %></p>
            <% } else { %>
            <p class="text-balance">
              Trained at <span class="text-[#3D3533] font-medium">London's premier makeup academies</span> and refined across three continents, I bring a global perspective to every bride's special day.
            </p>
            <p class="text-balance">
              My philosophy is simple — <span class="text-[#3D3533] font-medium">enhance, never mask</span>. Using luxury, hypoallergenic products, I create looks that photograph flawlessly from sunrise ceremonies to late-night celebrations.
            </p>
            <p class="text-balance italic border-l-2 border-[#D4A373]/30 pl-4 text-[#8C7D79]/80" style="font-family: 'Cormorant Infant', serif;">
              "Every stroke is a promise — to make you feel as radiant as the love you're celebrating."
            </p>
            <% } %>
          </div>
          <div class="flex flex-wrap gap-2 mt-2">
            <span class="badge bg-[#E8B4B8]/15 text-[#C4958F] border-none font-medium text-xs tracking-wide px-3 py-2" style="font-family: 'Cormorant Infant', serif;">Bridal Specialist</span>
            <span class="badge bg-[#D4A373]/15 text-[#C4956A] border-none font-medium text-xs tracking-wide px-3 py-2" style="font-family: 'Cormorant Infant', serif;">HD Airbrush</span>
            <span class="badge bg-[#E8B4B8]/15 text-[#C4958F] border-none font-medium text-xs tracking-wide px-3 py-2" style="font-family: 'Cormorant Infant', serif;">Luxury Products</span>
            <span class="badge bg-[#D4A373]/15 text-[#C4956A] border-none font-medium text-xs tracking-wide px-3 py-2" style="font-family: 'Cormorant Infant', serif;">Destination Ready</span>
          </div>
        </div>
      </section>

      <!-- ====== FLORAL DIVIDER ====== -->
      <div class="floral-divider px-8 py-3">
        <svg class="w-6 h-6 text-[#D4A373]/40 animate-rose-float" style="animation-delay: 2s;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/></svg>
      </div>

      <!-- ====== SERVICES ====== -->
      <section id="services" class="px-4 py-8">
        <div class="flex flex-col gap-3" data-reveal>
          <div class="flex items-center gap-3">
            <div class="w-8 h-px bg-gradient-to-r from-[#D4A373]/60 to-transparent"></div>
            <span class="text-[10px] uppercase tracking-[0.2em] text-[#D4A373] font-semibold" style="font-family: 'Cormorant Infant', serif;">Services</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#3D3533] leading-[1.1] text-balance" style="font-family: 'Cormorant Infant', serif;">
            Pricing &<br />Packages
          </h2>
          <p class="text-sm text-[#8C7D79]/60 leading-relaxed -mt-1 text-balance" style="font-family: 'Cormorant Infant', serif;">
            Custom quotes available for destination weddings & bridal parties
          </p>
        </div>

        <div class="flex flex-col gap-3 mt-6" data-reveal-stagger>
          <% if (user.services && user.services.length) { %>
          <% user.services.forEach(function(s) { %>
          <div class="pricing-card p-5 rounded-2xl bg-[#FAF0EA]/50 border border-[#E8B4B8]/20">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold text-[#3D3533]" style="font-family: 'Cormorant Infant', serif;"><%= s.name %></h3>
                <% if (s.desc) { %>
                <p class="text-sm text-[#8C7D79]/70 mt-1" style="font-family: 'Cormorant Infant', serif;"><%= s.desc %></p>
                <% } %>
              </div>
              <% if (s.price) { %>
              <div class="text-right flex-none">
                <p class="text-xl font-bold text-[#3D3533]/80" style="font-family: 'Cormorant Infant', serif;"><%= s.price %></p>
              </div>
              <% } %>
            </div>
          </div>
          <% }) %>
          <% } else { %>
          <div class="pricing-card popular p-5 rounded-2xl bg-[#FAF0EA] border border-[#D4A373]/30" style="box-shadow: 0 0 30px rgba(212,163,115,0.1);">
            <div class="pricing-badge bg-gradient-to-r from-[#D4A373] to-[#E8B4B8] text-white">Most Popular</div>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-xl font-bold text-[#3D3533]" style="font-family: 'Cormorant Infant', serif;">Bridal Package</h3>
                <p class="text-sm text-[#8C7D79]/70 mt-1" style="font-family: 'Cormorant Infant', serif;">Full bridal look incl. trial + HD airbrush</p>
                <ul class="mt-3 flex flex-col gap-1.5">
                  <li class="text-sm text-[#8C7D79] flex items-center gap-2"><svg class="w-3 h-3 text-[#D4A373] flex-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Pre-wedding trial session</li>
                  <li class="text-sm text-[#8C7D79] flex items-center gap-2"><svg class="w-3 h-3 text-[#D4A373] flex-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> HD Airbrush foundation</li>
                  <li class="text-sm text-[#8C7D79] flex items-center gap-2"><svg class="w-3 h-3 text-[#D4A373] flex-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Lash + touch-up kit included</li>
                </ul>
              </div>
              <div class="text-right flex-none">
                <p class="text-2xl font-bold gradient-text-rose" style="font-family: 'Great Vibes', cursive;">₹15K+</p>
                <p class="text-[10px] text-[#8C7D79]/40 tracking-wider uppercase" style="font-family: 'Cormorant Infant', serif;">Starting</p>
              </div>
            </div>
          </div>

          <div class="pricing-card p-5 rounded-2xl bg-[#FAF0EA]/50 border border-[#E8B4B8]/20">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold text-[#3D3533]" style="font-family: 'Cormorant Infant', serif;">Engagement</h3>
                <p class="text-sm text-[#8C7D79]/70 mt-1" style="font-family: 'Cormorant Infant', serif;">Radiant looks for roka & sangeet</p>
              </div>
              <div class="text-right flex-none">
                <p class="text-xl font-bold text-[#3D3533]/80" style="font-family: 'Cormorant Infant', serif;">₹10K+</p>
              </div>
            </div>
          </div>

          <div class="pricing-card p-5 rounded-2xl bg-[#FAF0EA]/50 border border-[#E8B4B8]/20">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold text-[#3D3533]" style="font-family: 'Cormorant Infant', serif;">Reception</h3>
                <p class="text-sm text-[#8C7D79]/70 mt-1" style="font-family: 'Cormorant Infant', serif;">Glamorous evening reception looks</p>
              </div>
              <div class="text-right flex-none">
                <p class="text-xl font-bold text-[#3D3533]/80" style="font-family: 'Cormorant Infant', serif;">₹12K+</p>
              </div>
            </div>
          </div>

          <div class="pricing-card p-5 rounded-2xl bg-[#FAF0EA]/50 border border-[#E8B4B8]/20">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
