                </div>
                <div class="whatsapp-field">
                  <label class="whatsapp-form-label" for="wa-phone">Phone Number</label>
                  <input type="tel" id="wa-phone" class="whatsapp-form-input" placeholder="e.g. +91 98765 43210" />
