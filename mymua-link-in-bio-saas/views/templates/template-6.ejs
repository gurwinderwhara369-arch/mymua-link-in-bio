        <div class="g-item" data-category="bridal" data-full="https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=1200&q=85&fit=crop" data-alt="Bridal"><img src="https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=400&q=80&fit=crop" alt="Bridal" loading="lazy" /></div>
        <div class="g-item" data-category="haldi" data-full="https://images.unsplash.com/photo-1563205673-e84964a73e6a?w=1200&q=85&fit=crop" data-alt="Haldi glow"><img src="https://images.unsplash.com/photo-1563205673-e84964a73e6a?w=400&q=80&fit=crop" alt="Haldi" loading="lazy" /></div>
        <div class="g-item" data-category="sangeet" data-full="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=1200&q=85&fit=crop" data-alt="Sangeet night"><img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=400&q=80&fit=crop" alt="Sangeet" loading="lazy" /></div>
