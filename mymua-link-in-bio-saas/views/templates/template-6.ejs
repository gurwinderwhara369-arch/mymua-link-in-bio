<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#1A0011" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="description" content="<%= user.bio ? user.bio.slice(0, 160) : user.name + ' — Indian Bridal Makeup. Royal luxury. Culture-rich. Haldi, Mehendi, Sangeet, Wedding.' %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Kalam:wght@300;400;700&family=Poppins:wght@300;400;500&family=Yatra+One&display=swap" rel="stylesheet" />
  <title><%= user.name %> — Indian Bridal Makeup</title>
  <style>
    :root {
      --maroon: #1A0011; --burgundy: #3D0814; --rich-red: #7B0F1A;
      --gold: #C8993A; --gold-light: #E8C547; --cream: #F9E4C8;
      --white: #FFFFFF; --muted: #8B7070;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--maroon); color: var(--cream);
      font-family: 'Poppins', sans-serif; font-weight: 300;
      min-height: 100dvh; overflow-x: hidden; -webkit-font-smoothing: antialiased;
    }
    .font-yatra { font-family: 'Yatra One', cursive; }
    .font-kalam { font-family: 'Kalam', cursive; }

    .wrap { max-width: 480px; margin: 0 auto; padding: 0 20px; position: relative; }

    /* SVG ornaments */
    .ornament { display: block; max-width: 52px; width: 100%; opacity: 0.55; flex-shrink: 0; }

    /* Shimmer rule */
    .shimmer { height: 1px; background: repeating-linear-gradient(90deg, transparent 0, transparent 6px, rgba(200,153,58,0.5) 6px, rgba(200,153,58,0.5) 14px); }

    /* Grain */
    .grain { position: absolute; inset: 0; pointer-events: none; opacity: 0.04; mix-blend-mode: overlay; }

    /* Reveal */
    .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.75s ease, transform 0.75s ease; }
    .reveal.visible { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* Service shimmer rows */
    .svc-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 10px; border-bottom: 1px solid rgba(200,153,58,0.12);
      transition: all 0.3s; border-radius: 6px;
    }
    .svc-row:last-child { border-bottom: none; }
    .svc-row:hover { background: linear-gradient(90deg, rgba(200,153,58,0.08) 0%, transparent 55%); padding-left: 14px; }

    /* Gallery grid */
    .g-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
    .g-item {
      position: relative; overflow: hidden; border-radius: 12px; cursor: pointer;
      aspect-ratio: 1; transition: box-shadow 0.4s, transform 0.3s;
    }
    .g-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.55s ease; }
    .g-item:hover img { transform: scale(1.06); }
    .g-item:hover { box-shadow: 0 0 0 3px rgba(200,153,58,0.5); }

    /* Filter pills */
    .f-pill {
      padding: 6px 16px; border: 1px solid rgba(200,153,58,0.3); border-radius: 999px;
      font-size: 11px; font-family: 'Poppins', sans-serif; letter-spacing: 0.05em;
      color: var(--cream); background: transparent; cursor: pointer; transition: all 0.25s;
    }
    .f-pill:hover, .f-pill.active { background: var(--gold); border-color: var(--gold); color: var(--maroon); }

    /* Lightbox */
    .lb {
      position: fixed; inset: 0; z-index: 100;
      background: rgba(5,0,4,0.95); display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.3s;
    }
    .lb.open { opacity: 1; pointer-events: auto; }
    .lb img { max-width: 92vw; max-height: 82dvh; object-fit: contain; border-radius: 12px; transform: scale(0.94); transition: transform 0.3s ease; }
    .lb.open img { transform: scale(1); }
    .lb-close {
      position: absolute; top: 20px; right: 20px; width: 40px; height: 40px; border-radius: 50%;
      border: 1px solid rgba(200,153,58,0.4); background: rgba(26,0,17,0.65); color: var(--gold);
      font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s;
    }
    .lb-close:hover { background: var(--gold); color: var(--maroon); }
    .lb-nav {
      position: absolute; top: 50%; transform: translateY(-50%); width: 40px; height: 40px; border-radius: 50%;
      border: 1px solid rgba(200,153,58,0.4); background: rgba(26,0,17,0.65); color: var(--gold);
      font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s;
    }
    .lb-nav:hover { background: var(--gold); color: var(--maroon); }
    .lb-prev { left: 10px; }
    .lb-next { right: 10px; }

    /* Availability date cards */
    .date-scroll { display: flex; gap: 10px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; padding-bottom: 4px; scrollbar-width: none; }
    .date-scroll::-webkit-scrollbar { display: none; }
    .date-card {
      flex: 0 0 auto; width: 76px; background: var(--burgundy); border: 1px solid rgba(200,153,58,0.3);
      border-radius: 14px; padding: 14px 8px; text-align: center; scroll-snap-align: start;
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .date-card:hover { transform: translateY(-3px); box-shadow: 0 4px 20px rgba(200,153,58,0.22); }
    .date-card .day { font-family: 'Yatra One', cursive; font-size: 20px; color: var(--gold); }
    .date-card .month { font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cream); margin-top: 2px; }
    .date-card .year { font-size: 9px; color: var(--muted); }
    .date-card .status { font-size: 9px; margin-top: 6px; color: #4ade80; }

    /* Stats marquee */
    .stats-row { display: flex; border-left: 1px solid rgba(200,153,58,0.2); border-right: 1px solid rgba(200,153,58,0.2); }
    .stat-chip { flex: 1; padding: 12px 8px; text-align: center; border-right: 1px solid rgba(200,153,58,0.2); }
    .stat-chip:last-child { border-right: none; }

    /* Specialty cards */
    .spec-card {
      background: transparent; border: 1px solid rgba(200,153,58,0.28); border-radius: 14px;
      padding: 18px 12px; text-align: center; transition: all 0.3s;
    }
    .spec-card:hover { background: rgba(200,153,58,0.07); border-color: rgba(200,153,58,0.65); transform: translateY(-3px); }

    /* Testimonial */
    .t-card { border-left: 3px solid var(--gold); border-radius: 0 12px 12px 0; padding: 18px 20px; background: transparent; }

    /* Contact row */
    .c-row {
      display: flex; align-items: center; gap: 14px; padding: 14px 16px; border-left: 2px solid var(--gold);
      background: rgba(61,8,20,0.65); border-radius: 0 12px 12px 0; transition: background 0.2s; text-decoration: none; color: inherit;
    }
    .c-row:hover { background: rgba(61,8,20,0.95); }

    /* Form */
    .b-input {
      width: 100%; padding: 13px 16px; background: var(--burgundy); border: 1px solid rgba(200,153,58,0.3);
      border-radius: 10px; color: var(--cream); font-family: 'Poppins', sans-serif; font-size: 14px; outline: none;
      transition: border-color 0.25s, box-shadow 0.25s;
    }
    .b-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(200,153,58,0.15); }
    .b-input::placeholder { color: rgba(249,228,200,0.28); }
    select.b-input { cursor: pointer; appearance: none; }
    select.b-input option { background: var(--burgundy); color: var(--cream); }
    textarea.b-input { resize: vertical; min-height: 100px; }

    /* WhatsApp FAB */
    .wa-fab {
      position: fixed; bottom: 24px; right: 22px; width: 56px; height: 56px; border-radius: 50%;
      background: #25D366; box-shadow: 0 4px 20px rgba(37,211,102,0.4); display: flex;
      align-items: center; justify-content: center; z-index: 90; text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .wa-fab:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(37,211,102,0.55); }
  </style>
</head>
<body class="bg-[#1A0011] text-[#F9E4C8] min-h-dvh overflow-x-hidden font-poppins">

  <!-- SVG defs -->
  <svg width="0" height="0" style="position:absolute;" aria-hidden="true">
    <defs>
      <filter id="grain"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter>
      <symbol id="lotus" viewBox="0 0 60 60">
        <g fill="none" stroke="#C8993A" stroke-width="1.2" stroke-linecap="round">
          <path d="M30 52c-2-8-10-14-18-12 4-6 10-10 18-10s14 4 18 10c-8-2-16 4-18 12z"/>
          <path d="M30 44c-1-5-5-9-10-8 2-3 6-5 10-5s8 2 10 5c-5-1-9 3-10 8z"/>
          <ellipse cx="30" cy="34" rx="4" ry="8" transform="rotate(0 30 34)"/><ellipse cx="30" cy="34" rx="4" ry="8" transform="rotate(60 30 34)"/><ellipse cx="30" cy="34" rx="4" ry="8" transform="rotate(120 30 34)"/>
          <circle cx="30" cy="34" r="2.5" fill="#C8993A"/>
        </g>
      </symbol>
    </defs>
  </svg>

  <!-- ====== HEADER ====== -->
  <header class="sticky top-0 z-50 backdrop-blur-md border-b border-[#C8993A]/10" style="background:rgba(26,0,17,0.82);">
    <div class="wrap flex items-center justify-between py-3">
      <span class="font-yatra text-sm text-[#C8993A] tracking-wide"><%= user.name %></span>
      <a href="#booking" class="text-[10px] font-poppins font-medium tracking-[0.15em] uppercase px-4 py-2 border border-[#C8993A]/40 text-[#C8993A] rounded-full hover:bg-[#C8993A] hover:text-[#1A0011] transition-all">Book Now</a>
    </div>
  </header>

  <!-- ====== HERO ====== -->
  <section class="relative min-h-[92dvh] flex items-center overflow-hidden" style="background:linear-gradient(135deg,#1A0011 0%,#3D0814 50%,#7B0F1A 100%);">
    <svg class="absolute top-5 right-5 ornament opacity-40 hidden sm:block" aria-hidden="true"><use href="#lotus"/></svg>
    <svg class="absolute bottom-12 left-5 ornament opacity-30 rotate-180 hidden sm:block" aria-hidden="true"><use href="#lotus"/></svg>
    <rect class="grain" width="100%" height="100%" filter="url(#grain)"/>
    <div class="wrap relative z-10 py-20">
      <div class="reveal">
        <p class="font-poppins text-[10px] tracking-[0.25em] uppercase text-[#C8993A] mb-3 font-medium">Indian Bridal Makeup</p>
        <h1 class="font-yatra text-[clamp(2.4rem,9vw,3.2rem)] text-[#C8993A] leading-tight mb-2"><%= user.name %></h1>
        <p class="font-poppins text-sm font-light text-[#F9E4C8]/80 mt-3 leading-relaxed"><%= user.title || 'For the bride who wears her culture like jewelry.' %></p>
      </div>
      <div class="reveal mt-5" data-delay="200">
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1.5 border border-[#C8993A]/25 rounded-full text-[10px] text-[#C8993A]/90 tracking-wide font-poppins">Indian Bridal</span>
          <span class="text-[#C8993A]/35 text-[10px] self-center">◆</span>
          <span class="px-3 py-1.5 border border-[#C8993A]/25 rounded-full text-[10px] text-[#C8993A]/90 tracking-wide font-poppins">Haldi</span>
          <span class="text-[#C8993A]/35 text-[10px] self-center">◆</span>
          <span class="px-3 py-1.5 border border-[#C8993A]/25 rounded-full text-[10px] text-[#C8993A]/90 tracking-wide font-poppins">Mehendi</span>
          <span class="text-[#C8993A]/35 text-[10px] self-center">◆</span>
          <span class="px-3 py-1.5 border border-[#C8993A]/25 rounded-full text-[10px] text-[#C8993A]/90 tracking-wide font-poppins">Sangeet</span>
          <span class="text-[#C8993A]/35 text-[10px] self-center">◆</span>
          <span class="px-3 py-1.5 border border-[#C8993A]/25 rounded-full text-[10px] text-[#C8993A]/90 tracking-wide font-poppins">Wedding</span>
          <span class="text-[#C8993A]/35 text-[10px] self-center">◆</span>
          <span class="px-3 py-1.5 border border-[#C8993A]/25 rounded-full text-[10px] text-[#C8993A]/90 tracking-wide font-poppins">Reception</span>
        </div>
      </div>
      <div class="reveal mt-8 flex flex-col gap-3" data-delay="300">
        <a href="#gallery" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-[#C8993A] text-[#1A0011] font-poppins font-medium text-sm tracking-wider rounded-full hover:bg-[#E8C547] transition-all active:scale-[0.97]">View Portfolio <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></a>
        <a href="#booking" class="inline-flex items-center justify-center px-7 py-3.5 border border-[#C8993A]/50 text-[#C8993A] font-poppins font-medium text-sm tracking-wider rounded-full hover:bg-[#C8993A] hover:text-[#1A0011] transition-all active:scale-[0.97]">Book Your Date</a>
      </div>
    </div>
  </section>

  <!-- ====== STATS ====== -->
  <section class="border-y border-[#C8993A]/15 py-5" style="background:rgba(61,8,20,0.6);">
    <div class="wrap">
      <div class="stats-row">
        <div class="stat-chip"><p class="font-yatra text-lg text-[#C8993A]">8+</p><p class="text-[10px] text-[#8B7070] mt-0.5 tracking-wide">Years</p></div>
        <div class="stat-chip"><p class="font-yatra text-lg text-[#C8993A]">350+</p><p class="text-[10px] text-[#8B7070] mt-0.5 tracking-wide">Brides</p></div>
        <div class="stat-chip"><p class="font-yatra text-lg text-[#C8993A]">4.9★</p><p class="text-[10px] text-[#8B7070] mt-0.5 tracking-wide">Rating</p></div>
        <div class="stat-chip"><p class="font-yatra text-lg text-[#C8993A]">20+</p><p class="text-[10px] text-[#8B7070] mt-0.5 tracking-wide">Cities</p></div>
      </div>
    </div>
  </section>

  <!-- ====== ABOUT ====== -->
  <section class="relative px-5 py-14 overflow-hidden" style="background:#3D0814;">
    <rect class="grain" width="100%" height="100%" filter="url(#grain)"/>
    <div class="wrap relative z-10">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1">
          <svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg>
          <p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#C8993A] font-medium">About</p>
        </div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#C8993A] mt-2 leading-tight">The Art of<br/>Bridal Beauty</h2>
        <div class="shimmer mt-5 mb-5 opacity-40"></div>
      </div>
      <div class="reveal" data-delay="100">
        <p class="text-sm text-[#F9E4C8]/80 leading-[1.85] text-balance max-w-md">
          <%= user.bio || 'With over eight years of experience in Indian bridal makeup, I specialize in creating timeless, culture-rich looks that honor tradition while embracing modern elegance. Every bride deserves to feel radiant on her wedding day.' %>
        </p>
      </div>
      <div class="reveal grid grid-cols-2 gap-3 mt-8" data-delay="200">
        <div class="spec-card"><div class="text-2xl mb-2">🤵‍♀️</div><p class="font-poppins text-sm font-medium text-[#C8993A]">Bridal</p><p class="text-[10px] text-[#8B7070] mt-0.5">Full wedding looks</p></div>
        <div class="spec-card"><div class="text-2xl mb-2">✨</div><p class="font-poppins text-sm font-medium text-[#C8993A]">Party</p><p class="text-[10px] text-[#8B7070] mt-0.5">Sangeet & events</p></div>
        <div class="spec-card"><div class="text-2xl mb-2">📸</div><p class="font-poppins text-sm font-medium text-[#C8993A]">Editorial</p><p class="text-[10px] text-[#8B7070] mt-0.5">Magazine ready</p></div>
        <div class="spec-card"><div class="text-2xl mb-2">🌴</div><p class="font-poppins text-sm font-medium text-[#C8993A]">Destination</p><p class="text-[10px] text-[#8B7070] mt-0.5">Travel with you</p></div>
      </div>
    </div>
  </section>

  <!-- ====== SERVICES ====== -->
  <section class="px-5 py-14 bg-white">
    <div class="wrap">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1"><svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg><p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#7B0F1A] font-medium">Services</p></div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#1A0011] mt-2 leading-tight">Bridal<br/>Packages</h2>
        <div class="shimmer mt-4 mb-6"></div>
      </div>
      <% if (user.services && user.services.length) { %>
      <div class="reveal" data-delay="100">
        <% user.services.forEach(function(s) { %>
        <div class="svc-row">
          <div><h3 class="font-poppins text-sm font-medium text-[#1A0011]"><%= s.name %></h3><% if (s.desc) { %><p class="text-xs text-[#8B7070] mt-0.5 leading-snug"><%= s.desc %></p><% } %></div>
          <p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4"><%= s.price %></p>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="reveal" data-delay="100">
        <div class="svc-row"><div><h3 class="font-poppins text-sm font-medium text-[#1A0011]">Haldi Ceremony</h3><p class="text-xs text-[#8B7070] mt-0.5">Fresh, glowing, dewy makeup</p></div><p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4">₹15K+</p></div>
        <div class="svc-row"><div><h3 class="font-poppins text-sm font-medium text-[#1A0011]">Mehendi Look</h3><p class="text-xs text-[#8B7070] mt-0.5">Soft glam, mehendi-friendly</p></div><p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4">₹12K+</p></div>
        <div class="svc-row"><div><h3 class="font-poppins text-sm font-medium text-[#1A0011]">Sangeet Night</h3><p class="text-xs text-[#8B7070] mt-0.5">Smokey eyes, statement glam</p></div><p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4">₹18K+</p></div>
        <div class="svc-row"><div><h3 class="font-poppins text-sm font-medium text-[#1A0011]">Wedding Day</h3><p class="text-xs text-[#8B7070] mt-0.5">Full bridal with pre-draping</p></div><p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4">₹25K+</p></div>
        <div class="svc-row"><div><h3 class="font-poppins text-sm font-medium text-[#1A0011]">Reception</h3><p class="text-xs text-[#8B7070] mt-0.5">Western glam, HD finish</p></div><p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4">₹20K+</p></div>
        <div class="svc-row"><div><h3 class="font-poppins text-sm font-medium text-[#1A0011]">Destination Wedding</h3><p class="text-xs text-[#8B7070] mt-0.5">Travel + full bridal package</p></div><p class="font-yatra text-base text-[#C8993A] whitespace-nowrap ml-4">₹45K+</p></div>
      </div>
      <% } %>
    </div>
  </section>

  <!-- ====== GALLERY ====== -->
  <section id="gallery" class="px-5 py-14" style="background:#1A0011;">
    <div class="wrap">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1"><svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg><p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#C8993A] font-medium">Portfolio</p></div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#C8993A] mt-2 leading-tight">Bridal<br/>Gallery</h2>
        <div class="shimmer mt-4 mb-5 opacity-40"></div>
      </div>
      <div class="reveal filter-pills mb-5" data-delay="100" id="filter-pills">
        <button class="f-pill active" data-filter="all">All</button>
        <button class="f-pill" data-filter="bridal">Bridal</button>
        <button class="f-pill" data-filter="haldi">Haldi</button>
        <button class="f-pill" data-filter="sangeet">Sangeet</button>
        <button class="f-pill" data-filter="reception">Reception</button>
      </div>
      <% if (user.gallery && user.gallery.length) { %>
      <div class="g-grid reveal" data-delay="150" id="g-grid">
        <% user.gallery.forEach(function(img, i) { %>
        <div class="g-item" data-category="<%= img.category || 'bridal' %>" data-full="<%= img.url %>" data-alt="<%= img.alt || 'Bridal makeup' %>">
          <img src="<%= img.url %>" alt="<%= img.alt || 'Bridal makeup' %>" loading="lazy" />
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="g-grid reveal" data-delay="150" id="g-grid">
        <div class="g-item" data-category="bridal" data-full="https://images.unsplash.com/photo-1583937312606-37a08645f78c?w=1200&q=85&fit=crop" data-alt="Indian bridal"><img src="https://images.unsplash.com/photo-1583937312606-37a08645f78c?w=400&q=80&fit=crop" alt="Bridal" loading="lazy" /></div>
        <div class="g-item" data-category="haldi" data-full="https://images.unsplash.com/photo-1511379347926-f7bd4237c0f0?w=1200&q=85&fit=crop" data-alt="Haldi"><img src="https://images.unsplash.com/photo-1511379347926-f7bd4237c0f0?w=400&q=80&fit=crop" alt="Haldi" loading="lazy" /></div>
        <div class="g-item" data-category="sangeet" data-full="https://images.unsplash.com/photo-1496442226666-8d4d0e62e6e9?w=1200&q=85&fit=crop" data-alt="Sangeet"><img src="https://images.unsplash.com/photo-1496442226666-8d4d0e62e6e9?w=400&q=80&fit=crop" alt="Sangeet" loading="lazy" /></div>
