  <!-- ====== BOOKING ====== -->
  <section id="booking" class="px-5 py-14" style="background:#3D0814;">
    <div class="wrap">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1"><svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg><p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#C8993A] font-medium">Book Now</p></div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#C8993A] mt-2 leading-tight">Book Your<br/>Bridal Makeup</h2>
        <div class="shimmer mt-4 mb-6 opacity-40"></div>
      </div>
      <% if (bookingStatus === 'success') { %>
      <div class="reveal mb-4 text-center" style="padding:16px 20px;background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.25);border-radius:2px;">
        <p style="color:#4ade80;font-weight:500;font-size:0.9rem;font-family:'Poppins',sans-serif;">✓ Booking sent successfully!</p>
        <p style="font-size:0.75rem;color:#C8993A/70;margin-top:4px;font-family:'Poppins',sans-serif;">I'll be in touch within 24 hours.</p>
      </div>
      <% } else if (bookingStatus && bookingStatus.startsWith('error')) { %>
      <div class="reveal mb-4 text-center" style="padding:16px 20px;background:rgba(220,80,80,0.08);border:1px solid rgba(220,80,80,0.25);border-radius:2px;">
        <p style="color:#dc5050;font-weight:500;font-size:0.9rem;font-family:'Poppins',sans-serif;">✗ <%= bookingStatus.replace('error=', '') %></p>
      </div>
      <% } %>
      <form action="/booking/<%= user.username %>" method="POST" class="reveal flex flex-col gap-4" data-delay="100" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Bride's Full Name <span class="text-[#C8993A]">*</span></label><input type="text" name="name" required class="b-input" placeholder="Enter bride's full name" autocomplete="name" /></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Groom's Full Name</label><input type="text" name="groom_name" class="b-input" placeholder="Groom's full name (optional)" /></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Email <span class="text-[#C8993A]">*</span></label><input type="email" name="email" required class="b-input" placeholder="your@email.com" autocomplete="email" /></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Phone <span class="text-[#C8993A]">*</span></label><input type="tel" name="phone" required class="b-input" placeholder="+91 98765 43210" autocomplete="tel" /></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Wedding Date <span class="text-[#C8993A]">*</span></label><input type="date" name="event_date" required class="b-input" min="<%= new Date().toISOString().split('T')[0] %>" /></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Ceremony Type <span class="text-[#C8993A]">*</span></label>
          <select name="service" required class="b-input">
            <option value="">Select ceremony type...</option>
            <option value="Haldi">Haldi</option><option value="Mehendi">Mehendi</option>
            <option value="Sangeet">Sangeet</option><option value="Wedding">Wedding</option>
            <option value="Reception">Reception</option><option value="Engagement">Engagement</option>
          </select></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Venue / City</label><input type="text" name="location" class="b-input" placeholder="e.g. Mumbai, Maharashtra" /></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Guest Count</label>
          <select name="guests" class="b-input">
            <option value="">Select...</option><option value="intimate">Intimate (&lt;50)</option>
            <option value="mid">Mid-size (50–200)</option><option value="grand">Grand (200+)</option>
          </select></div>
        <div><label class="block text-[10px] tracking-[0.15em] uppercase text-[#C8993A]/70 mb-1.5 font-medium font-poppins">Message</label><textarea name="notes" rows="3" class="b-input" placeholder="Tell me about your wedding vision..."></textarea></div>
        <button type="submit" class="w-full py-4 bg-[#C8993A] text-[#1A0011] font-poppins font-medium text-sm tracking-[0.15em] uppercase rounded-full hover:bg-[#E8C547] transition-all active:scale-[0.97] mt-2">Book Now</button>
      </form>
    </div>
  </section>

  <!-- ====== FOOTER ====== -->
  <footer class="border-t border-[#C8993A]/15 px-5 py-10 text-center">
    <div class="wrap">
      <svg class="ornament mx-auto mb-4 opacity-60" aria-hidden="true"><use href="#lotus"/></svg>
      <p class="font-yatra text-lg text-[#C8993A]">© <%= new Date().getFullYear() %> <%= user.name %></p>
      <p class="text-xs text-[#8B7070] mt-1.5 font-poppins">Crafting bridal dreams since 2017</p>
      <div class="shimmer mt-5 mb-4 opacity-20 mx-auto" style="max-width:100px;"></div>
    </div>
  </footer>

  <!-- WhatsApp FAB -->
  <% if (user.social && user.social.whatsapp) { %>
  <a href="https://wa.me/<%= user.social.whatsapp %>?text=Hi%20<%= encodeURIComponent(user.name) %>%21%20I%27d%20love%20to%20inquire%20about%20Indian%20bridal%20makeup." target="_blank" rel="noopener noreferrer" class="wa-fab" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
  <% } %>

  <script src="/js/shared.js"></script>
  <script>
    (function() {
      var pills = document.querySelectorAll('#filter-pills .f-pill');
      var items = document.querySelectorAll('#g-grid .g-item');
      pills.forEach(function(p) {
        p.addEventListener('click', function() {
          var f = p.dataset.filter;
          pills.forEach(function(x) { x.classList.remove('active'); }); p.classList.add('active');
          items.forEach(function(item) {
            item.style.display = (f === 'all' || item.dataset.category === f) ? '' : 'none';
          });
        });
      });
      document.querySelectorAll('input[type="date"]').forEach(function(inp) { inp.min = new Date().toISOString().split('T')[0]; });
    })();
  </script>
</body>
</html>
