  <!-- Lightbox -->
  <div class="lb" id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox" aria-hidden="true">
    <button class="lb-close" id="lb-close" aria-label="Close lightbox">✕</button>
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous">‹</button>
    <img src="" alt="" id="lb-img" />
    <button class="lb-nav lb-next" id="lb-next" aria-label="Next">›</button>
  </div>

  <!-- ====== TESTIMONIALS ====== -->
  <section class="px-5 py-14" style="background:#1A0011;">
    <div class="wrap">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1"><svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg><p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#C8993A] font-medium">Kind Words</p></div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#C8993A] mt-2 leading-tight">Bride<br/>Stories</h2>
        <div class="shimmer mt-4 mb-6 opacity-40"></div>
      </div>
      <% if (user.testimonials && user.testimonials.length) { %>
      <div class="flex flex-col gap-4">
        <% user.testimonials.forEach(function(t) { %>
        <div class="t-card reveal" data-delay="100">
          <p class="text-sm text-[#F9E4C8]/80 leading-relaxed italic">"<%= t.text %>"</p>
          <p class="mt-3 text-xs text-[#C8993A] font-medium">— <%= t.name %><%= t.event ? ', ' + t.event : '' %> <%= t.year || '' %></p>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="flex flex-col gap-4">
        <div class="t-card reveal" data-delay="100">
          <p class="text-sm text-[#F9E4C8]/80 leading-relaxed italic">"She made me feel like a queen on my wedding day. The makeup stayed flawless from 4AM to midnight. I cried when I saw myself — in the best way possible."</p>
          <p class="mt-3 text-xs text-[#C8993A] font-medium">— Priya Sharma, Wedding 2025</p>
        </div>
        <div class="t-card reveal" data-delay="200">
          <p class="text-sm text-[#F9E4C8]/80 leading-relaxed italic">"My Haldi look was so soft and glowing. Everyone asked who did my makeup. She understood exactly the vibe I wanted and delivered beyond expectations."</p>
          <p class="mt-3 text-xs text-[#C8993A] font-medium">— Anjali Mehta, Haldi 2025</p>
        </div>
        <div class="t-card reveal" data-delay="300">
          <p class="text-sm text-[#F9E4C8]/80 leading-relaxed italic">"Travelling with her to Udaipur for my destination wedding was the best decision. She brought her own kit, knew exactly what to bring, and made everything so easy."</p>
          <p class="mt-3 text-xs text-[#C8993A] font-medium">— Simran Kaur, Destination Wedding 2025</p>
        </div>
      </div>
      <% } %>
    </div>
  </section>

  <!-- ====== AVAILABILITY ====== -->
  <section id="availability" class="px-5 py-14" style="background:#3D0814;">
    <div class="wrap">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1"><svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg><p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#C8993A] font-medium">Availability</p></div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#C8993A] mt-2 leading-tight">Booking<br/>Dates</h2>
        <div class="shimmer mt-4 mb-5 opacity-40"></div>
        <div class="flex items-center gap-2 mb-5"><span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span><p class="text-xs text-[#C8993A] font-poppins tracking-wide">Open for 2026 bookings</p></div>
      </div>
      <div class="reveal date-scroll" data-delay="100">
        <div class="date-card"><p class="day">15</p><p class="month">Nov</p><p class="year">2026</p><p class="status">Open</p></div>
        <div class="date-card"><p class="day">20</p><p class="month">Nov</p><p class="year">2026</p><p class="status">Open</p></div>
        <div class="date-card"><p class="day">08</p><p class="month">Dec</p><p class="year">2026</p><p class="status">Open</p></div>
        <div class="date-card"><p class="day">12</p><p class="month">Dec</p><p class="year">2026</p><p class="status">Open</p></div>
        <div class="date-card"><p class="day">18</p><p class="month">Jan</p><p class="year">2027</p><p class="status">Open</p></div>
      </div>
    </div>
  </section>

  <!-- ====== CONTACT ====== -->
  <section id="contact" class="px-5 py-14" style="background:#1A0011;">
    <div class="wrap">
      <div class="reveal">
        <div class="flex items-center gap-3 mb-1"><svg class="ornament" aria-hidden="true"><use href="#lotus"/></svg><p class="text-[10px] font-poppins tracking-[0.25em] uppercase text-[#C8993A] font-medium">Get In Touch</p></div>
        <h2 class="font-yatra text-[clamp(1.8rem,6vw,2.4rem)] text-[#C8993A] mt-2 leading-tight">Let's<br/>Connect</h2>
        <div class="shimmer mt-4 mb-6 opacity-40"></div>
      </div>
      <div class="reveal flex flex-col gap-3" data-delay="100">
        <% if (user.social && user.social.phone) { %>
        <a href="tel:<%= user.social.phone %>" class="c-row"><div class="w-10 h-10 rounded-full border border-[#C8993A]/30 flex items-center justify-center flex-none"><svg class="w-4 h-4 text-[#C8993A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg></div><div><p class="text-sm font-medium text-[#F9E4C8]">Phone</p><p class="text-xs text-[#8B7070]">Call directly</p></div></a>
        <% } %>
        <% if (user.social && user.social.whatsapp) { %>
        <a href="https://wa.me/<%= user.social.whatsapp %>?text=Hi%20<%= encodeURIComponent(user.name) %>%21%20I%27d%20love%20to%20inquire%20about%20Indian%20bridal%20makeup%20for%20my%20wedding." target="_blank" rel="noopener noreferrer" class="c-row">
          <div class="w-10 h-10 rounded-full bg-[#25D366]/15 border border-[#25D366]/30 flex items-center justify-center flex-none"><svg class="w-4 h-4 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.82 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg></div>
          <div><p class="text-sm font-medium text-[#F9E4C8]">WhatsApp</p><p class="text-xs text-[#25D366]">Quick replies within 1h</p></div>
        </a>
        <% } %>
        <% if (user.social && user.social.instagram) { %>
        <a href="https://instagram.com/<%= user.social.instagram %>" target="_blank" rel="noopener noreferrer" class="c-row"><div class="w-10 h-10 rounded-full border border-[#C8993A]/30 flex items-center justify-center flex-none"><svg class="w-4 h-4 text-[#C8993A]" viewBox="0 0 24 24" fill="currentColor"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 016.11 2.525c.636-.247 1.363-.416 2.427-.465C8.83 2.013 9.075 2 12.315 2z"/></svg></div><div><p class="text-sm font-medium text-[#F9E4C8]">Instagram</p><p class="text-xs text-[#8B7070]">@<%= user.social.instagram %></p></div></a>
        <% } %>
        <% if (user.social && user.social.email) { %>
        <a href="mailto:<%= user.social.email %>" class="c-row"><div class="w-10 h-10 rounded-full border border-[#C8993A]/30 flex items-center justify-center flex-none"><svg class="w-4 h-4 text-[#C8993A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg></div><div><p class="text-sm font-medium text-[#F9E4C8]">Email</p><p class="text-xs text-[#8B7070]"><%= user.social.email %></p></div></a>
