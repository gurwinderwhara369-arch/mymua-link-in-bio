    <button class="lb-close" id="lb-close" aria-label="Close lightbox">✕</button>
    <img src="" alt="" id="lb-img" />
  </div>

  <!-- ====== TESTIMONIALS ====== -->
  <section class="testimonials" id="testimonials">
    <div class="wrap">
      <div class="reveal">
        <p class="sec-label">Kind Words</p>
        <h2 class="sec-title mt-1">Glow<br/>Stories</h2>
        <div class="peach-rule-sm"></div>
      </div>
      <div class="reveal mt-6" data-delay="150">
        <div class="t-card">
          <p class="t-text">"I've never felt more like myself. The glass skin bridal look held through tears, hugs, and 12 hours of dancing. My husband said I was glowing from the inside out."</p>
          <p class="t-author">Riya S. — Bride, 2025</p>
        </div>
        <div class="t-card">
          <p class="t-text">"As someone with sensitive skin, I was nervous about wedding makeup. She used only my approved products and the result was the most natural, radiant version of me."</p>
          <p class="t-author">Kavya M. — Bride, 2025</p>
        </div>
        <div class="t-card">
          <p class="t-text">"The dewy glow session before my sangeet was pure magic. I got so many compliments on my skin. People thought I was wearing no makeup at all."</p>
          <p class="t-author">Ananya P. — Sangeet, 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== AVAILABILITY ====== -->
  <section class="avail" id="availability">
    <div class="wrap">
      <div class="reveal">
        <p class="sec-label">Open Slots</p>
        <h2 class="sec-title mt-1">Book Your<br/>Glow Session</h2>
        <div class="peach-rule-sm"></div>
        <div class="flex items-center gap-2 mb-5">
          <span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>
          <p class="text-xs text-[#8B6F5E] tracking-wide">Limited slots — book 2–3 weeks ahead</p>
        </div>
      </div>
      <div class="reveal a-scroll" data-delay="150">
        <div class="a-card"><p class="a-day">10</p><p class="a-month">Jul</p><p class="a-status">2 slots</p></div>
        <div class="a-card"><p class="a-day">17</p><p class="a-month">Jul</p><p class="a-status">3 slots</p></div>
        <div class="a-card"><p class="a-day">24</p><p class="a-month">Jul</p><p class="a-status">1 slot</p></div>
        <div class="a-card"><p class="a-day">02</p><p class="a-month">Aug</p><p class="a-status">2 slots</p></div>
        <div class="a-card"><p class="a-day">09</p><p class="a-month">Aug</p><p class="a-status">3 slots</p></div>
      </div>
    </div>
  </section>

  <!-- ====== CONTACT ====== -->
  <section class="contact-sec" id="contact">
    <div class="wrap">
      <div class="reveal">
        <p class="sec-label">Get In Touch</p>
        <h2 class="sec-title mt-1">Let's<br/>Glow Together</h2>
        <div class="peach-rule-sm"></div>
      </div>
      <div class="reveal mt-6" data-delay="150">
        <% if (user.social && user.social.phone) { %>
        <a href="tel:<%= user.social.phone %>" class="c-row">
          <div class="c-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
          <div><p class="c-label">Phone</p><p class="c-val"><%= user.social.phone %></p></div>
        </a>
        <% } %>
        <% if (user.social && user.social.whatsapp) { %>
        <a href="https://wa.me/<%= user.social.whatsapp %>?text=Hi%20<%= encodeURIComponent(user.name) %>%2C%20I'm%20interested%20in%20soft%20glow%20makeup%20services." target="_blank" rel="noopener" class="c-row">
          <div class="c-icon" style="background:#25D366;"><svg viewBox="0 0 24 24" fill="#FFF"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></div>
          <div><p class="c-label">WhatsApp</p><p class="c-val">Chat for booking</p></div>
        </a>
        <% } %>
        <% if (user.social && user.social.instagram) { %>
        <a href="https://instagram.com/<%= user.social.instagram %>" target="_blank" rel="noopener" class="c-row">
          <div class="c-icon"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="#5C3D2E" stroke="none"/></svg></div>
          <div><p class="c-label">Instagram</p><p class="c-val">@<%= user.social.instagram %></p></div>
        </a>
        <% } %>
        <% if (user.social && user.social.email) { %>
        <a href="mailto:<%= user.social.email %>" class="c-row">
          <div class="c-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg></div>
          <div><p class="c-label">Email</p><p class="c-val"><%= user.social.email %></p></div>
        </a>
        <% } %>
      </div>
    </div>
  </section>

  <!-- ====== BOOKING ====== -->
  <section class="booking-sec" id="booking">
    <div class="wrap">
      <div class="reveal">
        <p class="sec-label">Book</p>
        <h2 class="sec-title mt-1">Let's Glow<br/>Together</h2>
        <div class="peach-rule-sm"></div>
      </div>
      <form action="/booking/<%= user.username %>" method="POST" class="reveal mt-2" data-delay="150" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="grid gap-4">
          <div>
            <label class="f-label" for="full_name">Full Name <span>*</span></label>
            <input class="f-input" type="text" id="full_name" name="full_name" placeholder="Your full name" required autocomplete="name" />
          </div>
          <div>
            <label class="f-label" for="email">Email <span>*</span></label>
            <input class="f-input" type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email" />
          </div>
          <div>
            <label class="f-label" for="phone">Phone <span>*</span></label>
            <input class="f-input" type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required autocomplete="tel" />
          </div>
          <div>
            <label class="f-label" for="event_date">Event Date</label>
            <input class="f-input" type="date" id="event_date" name="event_date" min="<%= new Date().toISOString().split('T')[0] %>" />
          </div>
          <div>
            <label class="f-label">Skin Type</label>
            <div class="skin-options" id="skin-options">
              <button type="button" class="skin-opt" data-value="Dry">Dry</button>
              <button type="button" class="skin-opt" data-value="Oily">Oily</button>
              <button type="button" class="skin-opt" data-value="Combination">Combination</button>
              <button type="button" class="skin-opt" data-value="Sensitive">Sensitive</button>
              <button type="button" class="skin-opt" data-value="Normal">Normal</button>
            </div>
            <input type="hidden" name="skin_type" id="skin_type" />
          </div>
          <div>
            <label class="f-label" for="desired_look">Desired Look</label>
            <select class="f-select" id="desired_look" name="desired_look">
              <option value="" disabled selected>Select look</option>
              <option value="Natural Glow">Natural Glow</option>
              <option value="Glass Skin">Glass Skin</option>
              <option value="Soft Glam">Soft Glam</option>
              <option value="Dewy Bridal">Dewy Bridal</option>
              <option value="No-Makeup Makeup">No-Makeup Makeup</option>
            </select>
          </div>
          <div>
            <label class="f-label" for="message">Message</label>
            <textarea class="f-textarea" id="message" name="message" placeholder="Tell me about your skin goals, event, and the glow you imagine..." rows="3"></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn-rose mt-5 w-full justify-center" style="padding:15px 28px;">Book My Session</button>
      </form>
    </div>
  </section>

  <!-- ====== FOOTER ====== -->
  <footer>
    <div class="wrap">
      <p>&copy; <%= new Date().getFullYear() %> <%= user.name %> — Your skin. Lit from within.</p>
    </div>
  </footer>

  <!-- WhatsApp FAB -->
  <% if (user.social && user.social.whatsapp) { %>
  <a href="https://wa.me/<%= user.social.whatsapp %>?text=Hi%20<%= encodeURIComponent(user.name) %>%2C%20I'm%20interested%20in%20soft%20glow%20makeup%20services." target="_blank" rel="noopener" class="wa-fab" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
  <% } %>

  <script>
    (function() {
      'use strict';
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var reveals = document.querySelectorAll('.reveal');
      if (reduced) { reveals.forEach(function(el) { el.classList.add('visible'); }); }
      else if ('IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              var d = parseInt(e.target.dataset.delay || '0', 10);
              setTimeout(function() { e.target.classList.add('visible'); }, d);
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        reveals.forEach(function(el) { obs.observe(el); });
      } else { reveals.forEach(function(el) { el.classList.add('visible'); }); }

      // Gallery filter
      var pills = document.querySelectorAll('#filter-pills .f-pill');
      var items = document.querySelectorAll('#g-grid .g-item');
      pills.forEach(function(p) {
        p.addEventListener('click', function() {
          var f = p.dataset.filter;
          pills.forEach(function(x) { x.classList.remove('active'); }); p.classList.add('active');
          items.forEach(function(item) {
            var cat = item.dataset.category || '';
            item.style.display = (f === 'all' || cat === f) ? '' : 'none';
          });
        });
      });

      // Lightbox
      var lb = document.getElementById('lightbox'), lbImg = document.getElementById('lb-img'), lbCl = document.getElementById('lb-close');
      document.querySelectorAll('.g-item').forEach(function(item) {
        item.addEventListener('click', function() {
          lbImg.src = item.dataset.full; lbImg.alt = item.querySelector('img').alt;
          lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden';
        });
      });
      function closeLb() { lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; setTimeout(function() { lbImg.src = ''; }, 300); }
      lbCl.addEventListener('click', closeLb);
      lb.addEventListener('click', function(e) { if (e.target === lb) closeLb(); });
      document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && lb.classList.contains('open')) closeLb(); });

      // Skin type selector
      var skinOpts = document.querySelectorAll('#skin-options .skin-opt');
      var skinInput = document.getElementById('skin_type');
      skinOpts.forEach(function(opt) {
        opt.addEventListener('click', function() {
          skinOpts.forEach(function(o) { o.classList.remove('selected'); });
          opt.classList.add('selected');
          skinInput.value = opt.dataset.value;
        });
      });

      document.querySelectorAll('input[type="date"]').forEach(function(inp) { inp.min = new Date().toISOString().split('T')[0]; });
    })();
  </script>
</body>
</html>
