<% let path = '/dashboard/templates' %>
<%- include('../partials/dash-head', { path }) %>
      <h1 class="text-xl font-bold mb-6">Templates</h1>
      <p class="text-sm text-zinc-500 mb-6">Click a template to switch. Your content stays the same — only the design changes.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <% var templates = [
          { id: 1, name: 'Twilight Glow', desc: 'Dark sunset, warm earthy tones, daisyUI', css: 'styles.css' },
          { id: 2, name: 'Champagne Blush', desc: 'Romantic gold & rose gold, serif fonts, petals', css: 'brochure.css' },
          { id: 3, name: 'Editorial Edge', desc: 'Monochrome + coral, sharp corners, bold', css: 'brochure2.css' },
        ]; %>
        <% templates.forEach(function(t) { %>
        <div class="bg-zinc-900 border <%= currentTemplate === t.id ? 'border-zinc-500' : 'border-zinc-800' %> rounded-xl overflow-hidden">
          <div class="aspect-[9/16] bg-zinc-800 flex items-center justify-center text-zinc-700 text-sm">
            <iframe src="/demo?template=<%= t.id %>" class="w-full h-full" loading="lazy" title="<%= t.name %> preview"></iframe>
          </div>
          <div class="p-4">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold"><%= t.name %></h3>
              <% if (currentTemplate === t.id) { %><span class="text-xs bg-zinc-700 text-zinc-300 px-2 py-0.5 rounded">Active</span><% } %>
            </div>
            <p class="text-xs text-zinc-500 mt-1"><%= t.desc %></p>
            <% if (currentTemplate !== t.id) { %>
            <form method="POST" class="mt-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="template_id" value="<%= t.id %>">
              <button type="submit" class="w-full py-2 bg-zinc-800 text-zinc-300 rounded-lg text-sm hover:bg-zinc-700 transition-colors">Switch to <%= t.name %></button>
            </form>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>
<%- include('../partials/dash-foot') %>
