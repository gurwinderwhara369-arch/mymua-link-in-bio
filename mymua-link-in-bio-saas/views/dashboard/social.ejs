<% let path = '/dashboard/social' %>
<%- include('../partials/dash-head', { path }) %>
      <h1 class="text-xl font-bold mb-6">Social Links</h1>
      <form method="POST" class="space-y-4 bg-zinc-900 border border-zinc-800 rounded-xl p-6 max-w-lg">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Phone</label>
          <input type="tel" name="phone" value="<%= content.social.phone %>" class="w-full px-4 py-3 bg-zinc-950 border border-zinc-800 rounded-lg text-sm" placeholder="+91 98765 43210">
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">WhatsApp Number</label>
          <input type="tel" name="whatsapp" value="<%= content.social.whatsapp %>" class="w-full px-4 py-3 bg-zinc-950 border border-zinc-800 rounded-lg text-sm" placeholder="+919999999999">
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Instagram Username</label>
          <input type="text" name="instagram" value="<%= content.social.instagram %>" class="w-full px-4 py-3 bg-zinc-950 border border-zinc-800 rounded-lg text-sm" placeholder="yourusername">
        </div>
        <div>
          <label class="block text-xs uppercase tracking-wider text-zinc-500 mb-1">Email</label>
          <input type="email" name="email" value="<%= content.social.email %>" class="w-full px-4 py-3 bg-zinc-950 border border-zinc-800 rounded-lg text-sm" placeholder="you@email.com">
        </div>
        <button type="submit" class="px-6 py-2.5 bg-zinc-100 text-zinc-900 rounded-lg text-sm font-medium hover:bg-zinc-200">Save</button>
      </form>
<%- include('../partials/dash-foot') %>
