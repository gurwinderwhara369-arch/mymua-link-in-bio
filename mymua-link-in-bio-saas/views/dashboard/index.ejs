<% let path = '/dashboard' %>
<%- include('../partials/dash-head', { path }) %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Your Page</p>
          <a href="/<%= user.username %>" target="_blank" class="text-lg font-semibold mt-1 block hover:text-zinc-300">@<%= user.username %></a>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Template</p>
          <p class="text-lg font-semibold mt-1">Template <%= user.template_id %></p>
        </div>
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
          <p class="text-zinc-500 text-xs uppercase tracking-wider">Bookings</p>
          <p class="text-lg font-semibold mt-1"><%= bookingCount %></p>
        </div>
      </div>

      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6">
        <h2 class="font-semibold mb-2">Quick Start</h2>
        <ol class="text-sm text-zinc-400 space-y-2 list-decimal list-inside">
          <li>Fill in your <a href="/dashboard/profile" class="text-zinc-300 hover:text-zinc-100 underline">Profile</a> — name, bio, photo</li>
          <li>Add your <a href="/dashboard/services" class="text-zinc-300 hover:text-zinc-100 underline">Services</a> with prices</li>
          <li>Upload <a href="/dashboard/gallery" class="text-zinc-300 hover:text-zinc-100 underline">Gallery</a> images</li>
          <li>Pick a <a href="/dashboard/templates" class="text-zinc-300 hover:text-zinc-100 underline">Template</a> that matches your vibe</li>
          <li>Share your page: <code class="bg-zinc-800 px-2 py-0.5 rounded text-zinc-300">/<%= user.username %></code></li>
        </ol>
      </div>
<%- include('../partials/dash-foot') %>
